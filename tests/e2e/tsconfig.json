{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "outDir": "./.tsc-out",
    "noEmit": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".playwright-out", ".tsc-out"]
}
