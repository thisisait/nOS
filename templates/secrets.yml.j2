---
# nOS – persisted runtime secrets
# Auto-generated by Ansible. DO NOT EDIT MANUALLY.
# File: ~/.nos/secrets.yml  (mode 0600, gitignored)
#
# Contains only secrets that encrypt persistent user data.
# Stateless secrets (session tokens, auth tokens) are not here — those are
# regenerated on every run intentionally.

# ── Infisical KMS ────────────────────────────────────────────────────────────
infisical_encryption_key: "{{ infisical_encryption_key }}"
infisical_auth_secret: "{{ infisical_auth_secret }}"

# ── Outline (database encrypted with this key) ───────────────────────────────
outline_secret_key: "{{ outline_secret_key }}"

# ── Bluesky PDS (PLC rotation key — identity root) ──────────────────────────
bluesky_pds_rotation_key: "{{ bluesky_pds_rotation_key }}"
bluesky_pds_jwt_secret: "{{ bluesky_pds_jwt_secret }}"

# ── Firefly III (Laravel APP_KEY — encrypts OAuth2 secrets + 2FA) ────────────
firefly_app_key: "{{ firefly_app_key }}"

# ── BookStack (Laravel APP_KEY — encrypts API tokens + 2FA backup codes) ─────
bookstack_app_key: "{{ bookstack_app_key }}"

# ── ONLYOFFICE (JWT secret shared with Nextcloud/BookStack host config) ──────
onlyoffice_jwt_secret: "{{ onlyoffice_jwt_secret }}"

# ── InfluxDB (admin token — Grafana datasource uses this) ────────────────────
influxdb_admin_token: "{{ influxdb_admin_token }}"

# ── Authentik (Django SECRET_KEY — CSRF + session signing) ───────────────────
authentik_secret_key: "{{ authentik_secret_key }}"

# ── Wing telemetry HMAC (callback plugin signs every batch with this; Bone
# events.py validates the signature). Both sides must agree — Bone reads it
# from the launchd plist, plugin reads it from this file. Defaults to
# bone_secret so a single rotation propagates to both ends.
wing_events_hmac_secret: "{{ wing_events_hmac_secret | default(bone_secret | default(global_password_prefix + '_pw_bone')) }}"
