{# ── Výpis _services jako JSON pole ─────────────────────────────────────── #}
{% for svc in _services %}
    {{ svc | to_json }}{{ "," if not loop.last else "" }}
{% endfor %}
  ],
  "languages": [
{% set _langs = [] %}
{% if install_php | default(true) %}
{% set _ = _langs.append({
  "name": "PHP",
  "version": php_version | default('8.3'),
  "enabled": true,
  "toggle_var": "install_php",
  "type": "homebrew",
  "sub_packages": (php_extensions | default([])) | map('regex_replace', '^php@[^-]+-', '') | list
}) %}
{% endif %}
{% if install_node | default(true) %}
{% set _ = _langs.append({
  "name": "Node.js",
  "version": node_nvm_version | default('lts/*'),
  "enabled": true,
  "toggle_var": "install_node",
  "type": "nvm",
  "sub_packages": node_global_packages | default([])
}) %}
{% endif %}
{% if install_bun | default(true) %}
{% set _ = _langs.append({
  "name": "Bun",
  "version": "latest",
  "enabled": true,
  "toggle_var": "install_bun",
  "type": "homebrew",
  "sub_packages": []
}) %}
{% endif %}
{% if install_python | default(true) %}
{% set _ = _langs.append({
  "name": "Python",
  "version": python_version | default('3.13'),
  "enabled": true,
  "toggle_var": "install_python",
  "type": "pyenv",
  "sub_packages": (pip_packages | default([])) | map(attribute='name') | list
}) %}
{% endif %}
{% if install_golang | default(true) %}
{% set _ = _langs.append({
  "name": "Go",
  "version": "latest",
  "enabled": true,
  "toggle_var": "install_golang",
  "type": "homebrew",
  "sub_packages": (go_packages | default([])) | map('regex_replace', '.*/([^/@]+)(@.*)?$', '\\1') | list
}) %}
{% endif %}
{% if install_dotnet | default(true) %}
{% set _ = _langs.append({
  "name": ".NET",
  "version": "latest",
  "enabled": true,
  "toggle_var": "install_dotnet",
  "type": "homebrew_cask",
  "sub_packages": (dotnet_global_tools | default([])) | map(attribute='name') | list
}) %}
{% endif %}
{% for lang in _langs %}
    {{ lang | to_json }}{{ "," if not loop.last else "" }}
{% endfor %}
  ],
  "packages": {
    "homebrew": {{ (homebrew_installed_packages | default([])) | to_json }},
    "homebrew_cask": {{ (homebrew_cask_apps | default([])) | to_json }}
  }
