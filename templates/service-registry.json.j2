{# ── Tier-2: apps onboarded via pazny.apps_runner ──────────────────────── #}
{# apps_extra_services is a runtime fact set by roles/pazny.apps_runner/    #}
{# tasks/post.yml — one entry per parsed apps/<name>.yml manifest. Each     #}
{# entry already has the same shape as Tier-1 entries above (registry_entry #}
{# in nos_apps_render).                                                     #}
{% for svc in (apps_extra_services | default([])) %}
{% set _ = _services.append(svc) %}
{% endfor %}
{# Inject derived `id` field on every service entry. Avoids having to
   patch all 56 _services.append blocks above; consumers (Bone /api/services,
   Wing SystemRepository::ingestRegistry) all expect an
   `id` slug. Derivation: toggle_var with `install_` prefix stripped
   (mirrors the PHP fallback in SystemRepository.php). Apps-runner-supplied
   entries already carry their own `id` (e.g. `app_documenso`); we only
   inject when missing. #}
{% set _services_with_ids = [] %}
{% for svc in _services %}
{%   if svc.get('id') %}
{%     set _ = _services_with_ids.append(svc) %}
{%   else %}
{%     set _tv = svc.get('toggle_var', '') %}
{%     set _id = (_tv[8:] if _tv.startswith('install_') else _tv) | default(svc.get('name','unknown') | lower | replace(' ','_'), true) %}
{%     set _ = _services_with_ids.append(svc | combine({'id': _id})) %}
{%   endif %}
{% endfor %}
{# ── Output _services as a JSON array ───────────────────────────────────── #}
{% for svc in _services_with_ids %}
    {{ svc | to_json }}{{ "," if not loop.last else "" }}
{% endfor %}
  ],
  "languages": [
