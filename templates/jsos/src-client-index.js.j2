import {
  Core,
  CoreServiceProvider,
  DesktopServiceProvider,
  VFSServiceProvider,
  NotificationServiceProvider,
  SettingsServiceProvider,
  AuthServiceProvider,
} from '@osjs/client';

import { PanelServiceProvider } from '@osjs/panels';
import { GUIServiceProvider } from '@osjs/gui';
import { DialogServiceProvider } from '@osjs/dialogs';

import './index.scss';

const init = () => {
  const osjs = new Core({
    auth: {
      ui: {
        title: 'jsOS — Homelab Desktop',
        stamp: 'Bluesky handle + app password',
      },
      login: {
        username: null,
        password: null,
      },
    },
    desktop: {
      settings: {
        font: 'Roboto',
        theme: 'StandardTheme',
        sounds: 'FreedesktopSounds',
        icons: 'GnomeIcons',
        animations: false,
      },
    },
    vfs: {
      defaultPath: 'home:/',
      mountpoints: [
        { name: 'home', label: 'Domov' },
{% if install_rustfs | default(false) %}
        { name: 'cloud', label: 'Cloud (S3)' },
{% endif %}
      ],
    },
  }, {});

  // ── Register service providers ──────────────────────────────────────────
  osjs.register(CoreServiceProvider);
  osjs.register(DesktopServiceProvider);
  osjs.register(VFSServiceProvider);
  osjs.register(NotificationServiceProvider);
  osjs.register(SettingsServiceProvider, { before: true });
  osjs.register(AuthServiceProvider, { before: true });
  osjs.register(PanelServiceProvider);
  osjs.register(GUIServiceProvider);
  osjs.register(DialogServiceProvider);

  // ── After boot: register homelab iframe launchers ───────────────────────
  osjs.on('osjs/core:started', () => {
    // Fetch enabled services and register iframe launchers
    fetch('/api/homelab/services')
      .then((r) => {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then((services) => {
        services.forEach((svc) => {
          // Register each service as a launchable application
          osjs.make('osjs/packages').register(
            `HomelabFrame_${svc.id}`,
            (core, args, options, metadata) => {
              const proc = core.make('osjs/application', {
                args,
                options,
                metadata: {
                  ...metadata,
                  name: `HomelabFrame_${svc.id}`,
                  title: { en_EN: svc.name },
                  category: 'homelab',
                  singleton: false,
                },
              });

              proc.createWindow({
                id: `HomelabFrame_${svc.id}_${Date.now()}`,
                title: svc.name,
                icon: svc.icon || null,
                dimension: { width: 1200, height: 800 },
                position: { left: 50 + Math.random() * 100, top: 50 + Math.random() * 100 },
              })
              .on('destroy', () => proc.destroy())
              .render(($content) => {
                const iframe = document.createElement('iframe');
                iframe.src = svc.url;
                iframe.setAttribute('sandbox', 'allow-scripts allow-forms allow-popups allow-modals');
                iframe.style.cssText = 'width:100%;height:100%;border:none;background:#fff;';
                $content.appendChild(iframe);
              });

              return proc;
            }
          );
        });

        console.log(`[jsOS] Registered ${services.length} homelab service launchers`);
      })
      .catch((err) => console.warn('[jsOS] Service fetch error:', err));
  });

  osjs.boot();
};

window.addEventListener('DOMContentLoaded', () => init());
