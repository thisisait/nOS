// {{ ansible_managed | default('Ansible managed') }}
// ==============================================================================
// jsOS – Client styles (custom login + homelab branding)
// ==============================================================================

// ── Login screen ────────────────────────────────────────────────────────────
.osjs-login {
  background: linear-gradient(135deg, #0a0f1c 0%, #1a1f3c 50%, #0d1526 100%);

  &::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(0, 133, 255, 0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(99, 102, 241, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }
}

.osjs-login-box {
  background: rgba(15, 23, 42, 0.85);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(99, 102, 241, 0.2);
  border-radius: 12px;
  padding: 2rem;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  max-width: 380px;
}

.osjs-login-header {
  text-align: center;
  margin-bottom: 1.5rem;

  h1 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #e2e8f0;
    letter-spacing: -0.02em;
  }
}

.osjs-login-stamp {
  display: block;
  text-align: center;
  font-size: 0.8rem;
  color: #64748b;
  margin-top: 0.25rem;
}

.osjs-login-field {
  margin-bottom: 1rem;

  input {
    width: 100%;
    padding: 0.65rem 0.85rem;
    background: rgba(30, 41, 59, 0.8);
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: 6px;
    color: #e2e8f0;
    font-size: 0.9rem;
    transition: border-color 0.2s;

    &::placeholder {
      color: #475569;
    }

    &:focus {
      outline: none;
      border-color: rgba(99, 102, 241, 0.5);
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }
  }
}

.osjs-login-button {
  width: 100%;
  padding: 0.7rem;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: #fff;
  border: none;
  border-radius: 6px;
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: opacity 0.2s;

  &:hover {
    opacity: 0.9;
  }
}

// ── HomelabPortal app ────────────────────────────────────────────────────────
.homelab-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 1rem;
  padding: 1rem;
  overflow-y: auto;
  height: 100%;
}

.homelab-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1.25rem 1rem;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.15s ease;
  text-align: center;

  &:hover {
    background: #eff6ff;
    border-color: #93c5fd;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1);
  }
}

.homelab-card-icon {
  font-size: 2rem;
  margin-bottom: 0.5rem;
}

.homelab-card-name {
  font-weight: 600;
  font-size: 0.85rem;
  color: #1e293b;
}

.homelab-card-desc {
  font-size: 0.7rem;
  color: #64748b;
  margin-top: 0.25rem;
}

.homelab-card-status {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #22c55e;
  margin-top: 0.5rem;

  &.offline {
    background: #ef4444;
  }
}
