{# ── Definice stylů ─────────────────────────────────────────────────────── #}
{% set S_dot = "display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px;background:#3fb950" %}
{% set S_card = "background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:16px;display:inline-block;width:210px;vertical-align:top;margin:6px" %}
{% set S_link = "color:#58a6ff;text-decoration:none;font-weight:600;font-size:14px" %}
{% set S_desc = "color:rgba(230,237,243,0.6);font-size:12px;margin:4px 0 8px 0" %}
{% set S_meta = "font-size:11px;color:rgba(230,237,243,0.4)" %}
{% set S_badge = "background:rgba(88,166,255,0.15);color:#58a6ff;padding:2px 6px;border-radius:3px;margin-left:4px;font-size:10px" %}
{% set S_th = "text-align:left;padding:8px 12px;border-bottom:2px solid rgba(255,255,255,0.1);color:rgba(230,237,243,0.6);font-weight:600;font-size:13px" %}
{% set S_td = "padding:6px 12px;border-bottom:1px solid rgba(255,255,255,0.05);font-size:13px" %}
{% set S_port = "font-family:monospace;color:#79c0ff" %}
{% set S_docker = "color:#58a6ff" %}
{% set S_brew = "color:#f0883e" %}
{% set S_bin = "color:#d2a8ff" %}
{% set S_name = "font-weight:600;font-size:14px;color:#e6edf3" %}
{% set S_ver = "color:rgba(230,237,243,0.5);font-size:12px;margin-left:6px" %}
{% set S_sub = "font-size:12px;color:rgba(230,237,243,0.5);padding:1px 0" %}
{% set S_section = "font-size:12px;font-weight:600;color:rgba(230,237,243,0.8);margin:12px 0 6px;padding-bottom:4px;border-bottom:1px solid rgba(255,255,255,0.1)" %}
{% set S_pkg = "font-size:11px;font-family:monospace;color:rgba(230,237,243,0.6);background:rgba(255,255,255,0.04);padding:2px 6px;border-radius:3px;display:inline-block;margin:2px 3px" %}
{# ── Makro pro klikatelnou kartu (subdoména + Tailscale port) ──────────── #}
{% set _ts = tailscale_hostname | default('') %}
{% macro card(name, domain, port, desc, badge) %}
<div style='{{ S_card }}'><span style='{{ S_dot }}'></span><a href='https://{{ domain }}' target='_blank' style='{{ S_link }}'>{{ name }}</a><div style='{{ S_desc }}'>{{ desc }}</div><div style='{{ S_meta }}'><a href='https://{{ domain }}' style='color:rgba(230,237,243,0.5);text-decoration:none'>{{ domain }}</a> · <a href='http://{{ _ts if _ts else "localhost" }}:{{ port }}' style='{{ S_port }};text-decoration:none'>:{{ port }}</a> <span style='{{ S_badge }}'>{{ badge }}</span></div></div>
{% endmacro %}
