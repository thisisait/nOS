# =============================================================================
# OBSERVABILITY STACK – Grafana + Prometheus + Loki + Tempo
# Generováno Ansiblem – NEUPRAVUJ ručně
#
# Host-side služby (Alloy, node_exporter, nginx/phpfpm exportery) zůstávají
# na hostu a jsou z kontejnerů dostupné přes host.docker.internal.
#
# Veskere services byly extrahovane do samostatnych roli:
#   - pazny.grafana    (Wave 2.1) → overrides/grafana.yml
#   - pazny.prometheus (Wave 2.2) → overrides/prometheus.yml
#   - pazny.loki       (Wave 2.2) → overrides/loki.yml
#   - pazny.tempo      (Wave 2.2) → overrides/tempo.yml
#
# core-up.yml merguje fragmenty pres `docker compose -f base.yml
# -f overrides/*.yml up`. Tento base soubor vlastni jen top-level
# `networks:` deklaraci, kterou role fragmenty referencuji podle jmena.
# =============================================================================

networks:
  observability_net:
    driver: bridge
  {{ stacks_shared_network }}:
    external: true
