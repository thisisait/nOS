# =============================================================================
# B2B STACK – CRM/ERP, Helpdesk, Chat, Knowledge Base
# Generováno Ansiblem – NEUPRAVUJ ručně
#
# Sdílené DB z infra stacku: MariaDB (shared_net:mariadb),
# PostgreSQL (shared_net:postgresql), Redis (shared_net:redis)
#
# Service bloky byly extrahovány do roles/pazny.*/ (Wave 2.2):
#   - erpnext   → roles/pazny.erpnext/templates/compose.yml.j2
#                 (6 services + named volume erpnext_sites)
#   - freescout → roles/pazny.freescout/templates/compose.yml.j2
#   - outline   → roles/pazny.outline/templates/compose.yml.j2
# Role fragments jsou merged pres `docker compose -f <base> -f <override>...`
# v tasks/stacks/stack-up.yml (find + -f loop).
# =============================================================================

services: {}

{# Mattermost odstraněn – nemá ARM64 FOSS image. Chat přes Bluesky PDS nebo Nextcloud Talk. #}

networks:
  b2b_net:
    driver: bridge
  {{ stacks_shared_network }}:
    external: true
