# =============================================================================
# B2B STACK – CRM/ERP, Helpdesk, Chat, Knowledge Base
# Generováno Ansiblem – NEUPRAVUJ ručně
#
# Sdílené DB z infra stacku: MariaDB (shared_net:mariadb),
# PostgreSQL (shared_net:postgresql), Redis (shared_net:redis)
# =============================================================================

services:

{% if install_erpnext | default(false) %}
  # ── ERPNext (Frappe framework) ─────────────────────────────────────────────
  # ERPNext vyžaduje: MariaDB + Redis (oboje z infra stacku)

  erpnext-configurator:
    image: frappe/erpnext:{{ erpnext_version | default('v15') }}
    restart: "no"
    entrypoint: ["bash", "-c"]
    command:
      - >
        cd /home/frappe/frappe-bench/sites &&
        [ -f common_site_config.json ] && echo "Already configured" && exit 0;
        echo '{}' > common_site_config.json &&
        echo 'frappe' > apps.txt &&
        bench set-config -g db_host mariadb &&
        bench set-config -g db_port 3306 &&
        bench set-config -g redis_cache redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/0 &&
        bench set-config -g redis_queue redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/1 &&
        bench set-config -g redis_socketio redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/2 &&
        bench new-site {{ erpnext_site_name | default('erp.dev.local') }}
        --no-mariadb-socket
        --db-root-username=root
        --db-root-password={{ mariadb_root_password }}
        --admin-password={{ erpnext_admin_password | default(global_password_prefix + '_pw_erpnext') }}
        --install-app erpnext
        --set-default
    volumes:
      - erpnext_sites:/home/frappe/frappe-bench/sites
    environment:
      DB_HOST: mariadb
      DB_PORT: "3306"
      DB_ROOT_USER: root
      DB_ROOT_PASSWORD: "{{ mariadb_root_password }}"
      REDIS_CACHE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/0"
      REDIS_QUEUE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/1"
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    mem_limit: {{ erpnext_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

  erpnext-backend:
    image: frappe/erpnext:{{ erpnext_version | default('v15') }}
    restart: unless-stopped
    volumes:
      - erpnext_sites:/home/frappe/frappe-bench/sites
    environment:
      DB_HOST: mariadb
      DB_PORT: "3306"
      DB_ROOT_USER: root
      DB_ROOT_PASSWORD: "{{ mariadb_root_password }}"
      REDIS_CACHE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/0"
      REDIS_QUEUE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/1"
      REDIS_SOCKETIO: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/2"
      SOCKETIO_PORT: "9000"
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ erpnext_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

  erpnext-frontend:
    image: frappe/erpnext:{{ erpnext_version | default('v15') }}
    restart: unless-stopped
    command: nginx-entrypoint.sh
    ports:
{% if services_lan_access | default(false) %}
      - "{{ erpnext_port | default(8082) }}:8080"
{% else %}
      - "127.0.0.1:{{ erpnext_port | default(8082) }}:8080"
{% endif %}
    volumes:
      - erpnext_sites:/home/frappe/frappe-bench/sites
    environment:
      BACKEND: erpnext-backend:8000
      SOCKETIO: erpnext-backend:9000
      UPSTREAM_REAL_IP_ADDRESS: "127.0.0.1"
      UPSTREAM_REAL_IP_HEADER: "X-Forwarded-For"
      UPSTREAM_REAL_IP_RECURSIVE: "off"
      FRAPPE_SITE_NAME_HEADER: "$$host"
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ erpnext_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

  erpnext-queue-short:
    image: frappe/erpnext:{{ erpnext_version | default('v15') }}
    restart: unless-stopped
    command: bench worker --queue short
    volumes:
      - erpnext_sites:/home/frappe/frappe-bench/sites
    environment:
      DB_HOST: mariadb
      DB_PORT: "3306"
      DB_ROOT_USER: root
      DB_ROOT_PASSWORD: "{{ mariadb_root_password }}"
      REDIS_CACHE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/0"
      REDIS_QUEUE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/1"
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ erpnext_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

  erpnext-queue-long:
    image: frappe/erpnext:{{ erpnext_version | default('v15') }}
    restart: unless-stopped
    command: bench worker --queue long
    volumes:
      - erpnext_sites:/home/frappe/frappe-bench/sites
    environment:
      DB_HOST: mariadb
      DB_PORT: "3306"
      DB_ROOT_USER: root
      DB_ROOT_PASSWORD: "{{ mariadb_root_password }}"
      REDIS_CACHE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/0"
      REDIS_QUEUE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/1"
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ erpnext_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

  erpnext-scheduler:
    image: frappe/erpnext:{{ erpnext_version | default('v15') }}
    restart: unless-stopped
    command: bench schedule
    volumes:
      - erpnext_sites:/home/frappe/frappe-bench/sites
    environment:
      DB_HOST: mariadb
      DB_PORT: "3306"
      DB_ROOT_USER: root
      DB_ROOT_PASSWORD: "{{ mariadb_root_password }}"
      REDIS_CACHE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/0"
      REDIS_QUEUE: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379/1"
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ erpnext_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{% if install_freescout | default(false) %}
  # ── FreeScout (helpdesk/ticketing) ─────────────────────────────────────────
  freescout:
    image: tiredofit/freescout:{{ freescout_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ freescout_port | default(8090) }}:80"
{% else %}
      - "127.0.0.1:{{ freescout_port | default(8090) }}:80"
{% endif %}
    volumes:
      - {{ freescout_data_dir | default(ansible_facts['env']['HOME'] + '/freescout/data') }}:/data
    environment:
      CONTAINER_NAME: freescout
      DB_HOST: mariadb
      DB_PORT: "3306"
      DB_NAME: "{{ freescout_db_name | default('freescout') }}"
      DB_USER: "{{ freescout_db_user | default('freescout') }}"
      DB_PASS: "{{ freescout_db_password | default(global_password_prefix + '_pw_freescout') }}"
      SITE_URL: "https://{{ freescout_domain | default('helpdesk.dev.local') }}"
      ADMIN_EMAIL: "{{ freescout_admin_email | default('admin@dev.local') }}"
      ADMIN_PASS: "{{ freescout_admin_password | default(global_password_prefix + '_pw_freescout') }}"
      TIMEZONE: "{{ freescout_timezone | default('Europe/Prague') }}"
      ENABLE_SSL_PROXY: "TRUE"
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ freescout_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ docker_cpus_light | default('0.5') }}

{% endif %}
{# Mattermost odstraněn – nemá ARM64 FOSS image. Chat přes Bluesky PDS nebo Nextcloud Talk. #}
{% if install_outline | default(false) %}
  # ── Outline (team wiki / knowledge base) ───────────────────────────────────
  outline:
    image: outlinewiki/outline:{{ outline_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ outline_port | default(3005) }}:3000"
{% else %}
      - "127.0.0.1:{{ outline_port | default(3005) }}:3000"
{% endif %}
    volumes:
      - {{ outline_data_dir | default(ansible_facts['env']['HOME'] + '/outline/data') }}:/var/lib/outline/data
{% if install_authentik | default(false) %}
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/usr/local/share/ca-certificates/mkcert-ca.crt:ro
{% endif %}
    environment:
      NODE_ENV: production
      SECRET_KEY: "{{ outline_secret_key | default(global_password_prefix + '_pw_outline_secret') }}"
      UTILS_SECRET: "{{ outline_utils_secret | default(global_password_prefix + '_pw_outline_utils') }}"
      DATABASE_URL: "postgres://{{ outline_db_user | default('outline') }}:{{ outline_db_password | default(global_password_prefix + '_pw_outline') }}@postgresql:5432/{{ outline_db_name | default('outline') }}"
      PGSSLMODE: "disable"
      REDIS_URL: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379"
      URL: "https://{{ outline_domain | default('wiki.dev.local') }}"
      PORT: "3000"
      FORCE_HTTPS: "false"
      FILE_STORAGE: local
      FILE_STORAGE_LOCAL_ROOT_DIR: /var/lib/outline/data
{% if install_authentik | default(false) %}
      # ── Authentik SSO (OIDC) ───────────────────────────────────────────────
      OIDC_CLIENT_ID: "{{ authentik_oidc_outline_client_id }}"
      OIDC_CLIENT_SECRET: "{{ authentik_oidc_outline_client_secret }}"
      OIDC_AUTH_URI: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/authorize/"
      OIDC_TOKEN_URI: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/token/"
      OIDC_USERINFO_URI: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/userinfo/"
      OIDC_USERNAME_CLAIM: "preferred_username"
      OIDC_DISPLAY_NAME: "Authentik"
      OIDC_SCOPES: "openid profile email"
      NODE_EXTRA_CA_CERTS: "/usr/local/share/ca-certificates/mkcert-ca.crt"
{% endif %}
{% if install_authentik | default(false) %}
    extra_hosts:
      - "{{ authentik_domain | default('auth.dev.local') }}:host-gateway"
{% endif %}
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ outline_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}

networks:
  b2b_net:
    driver: bridge
  {{ stacks_shared_network }}:
    external: true

{% if install_erpnext | default(false) %}
# ── ERPNext: named volume pro frappe-bench/sites ────────────────────────────
# Na macOS Docker Desktop je bind mount pres VirtioFS nestabilni pro Frappe
# filelock operace (OSError [Errno 5] Input/output error v
# filelock.__exit__). Named volume se uklada uvnitr Docker VM (linuxkit),
# mimo macOS host filesystem → native ext4, zadne VirtioFS crossing, full
# speed a stability. Blank reset vymaze volume via `docker compose down -v`
# + `docker volume prune -f -a` v blank-reset.yml.
volumes:
  erpnext_sites:
    driver: local
{% endif %}
