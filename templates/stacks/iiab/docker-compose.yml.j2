# =============================================================================
# IIAB STACK – self-hosted knowledge & media services
# Generováno Ansiblem – NEUPRAVUJ ručně
#
# Wave 2 role extraction — všechny services přesunuty do roles/pazny.*/
# a renderuji se do {{ stacks_dir }}/iiab/overrides/*.yml.
# stack-up.yml je merguje pres `docker compose -f base.yml -f overrides/*.yml up`.
#
# Mapa fragmentů:
#   wordpress     → roles/pazny.wordpress/       (Wave 2.2)
#   nextcloud     → roles/pazny.nextcloud/       (Wave 2.2)
#   n8n           → roles/pazny.n8n/             (Wave 2.2)
#   puter         → roles/pazny.puter/           (Wave 2.2)
#   kiwix         → roles/pazny.kiwix/           (Wave 2.2)
#   jellyfin      → roles/pazny.jellyfin/        (Wave 2.2)
#   homeassistant → roles/pazny.homeassistant/   (Wave 2.2)
#   calibre-web   → roles/pazny.calibre_web/     (Wave 2.2)
#   tileserver    → roles/pazny.offline_maps/    (Wave 2.2)
#   open-webui    → roles/pazny.open_webui/      (Wave 2.2)
#   uptime-kuma   → roles/pazny.uptime_kuma/     (Wave 2.2)
#   vaultwarden   → roles/pazny.vaultwarden/     (Wave 2.2)
#   rustfs        → roles/pazny.rustfs/          (Wave 2.2)
# =============================================================================

services: {}

networks:
  iiab_net:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16
  {{ stacks_shared_network }}:
    external: true
