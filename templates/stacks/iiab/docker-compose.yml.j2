# =============================================================================
# IIAB STACK – self-hosted knowledge & media services
# Generováno Ansiblem – NEUPRAVUJ ručně
# =============================================================================

services:

{# MariaDB přesunuta do infra stacku – služby se připojují přes shared_net #}
{% if install_wordpress | default(false) %}
  wordpress:
    image: wordpress:{{ wordpress_version | default('latest') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ wordpress_port | default(8084) }}:80"
    volumes:
      - {{ wordpress_dir }}:/var/www/html
    environment:
      WORDPRESS_DB_HOST: "{% if install_mariadb | default(false) %}mariadb{% else %}{{ wordpress_db_host | default('127.0.0.1') }}{% endif %}"
      WORDPRESS_DB_USER: "{{ wordpress_db_user }}"
      WORDPRESS_DB_PASSWORD: "{{ wordpress_db_password }}"
      WORDPRESS_DB_NAME: "{{ wordpress_db_name }}"
      WORDPRESS_TABLE_PREFIX: "{{ wordpress_table_prefix | default('wp_') }}"
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"

{% endif %}
{% if install_nextcloud | default(false) %}
  nextcloud:
    image: nextcloud:{{ nextcloud_version | default('stable') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ nextcloud_port | default(8085) }}:80"
{% else %}
      - "127.0.0.1:{{ nextcloud_port | default(8085) }}:80"
{% endif %}
    volumes:
      - {{ nextcloud_dir }}:/var/www/html
      - {{ nextcloud_data_dir }}:/data
    environment:
      MYSQL_HOST: "{% if install_mariadb | default(false) %}mariadb{% else %}{{ nextcloud_db_host | default('127.0.0.1') }}{% endif %}"
      MYSQL_DATABASE: "{{ nextcloud_db_name }}"
      MYSQL_USER: "{{ nextcloud_db_user }}"
      MYSQL_PASSWORD: "{{ nextcloud_db_password }}"
      NEXTCLOUD_ADMIN_USER: "{{ nextcloud_admin_user }}"
      NEXTCLOUD_ADMIN_PASSWORD: "{{ nextcloud_admin_password }}"
      NEXTCLOUD_DATA_DIR: "/data"
      NEXTCLOUD_TRUSTED_DOMAINS: "{{ nextcloud_domain | default('cloud.dev.local') }} localhost 127.0.0.1"
      OVERWRITEPROTOCOL: "https"
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"

{% endif %}
{% if install_n8n | default(false) %}
  n8n:
    image: n8nio/n8n:{{ n8n_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ n8n_port | default(5678) }}:5678"
{% else %}
      - "127.0.0.1:{{ n8n_port | default(5678) }}:5678"
{% endif %}
    volumes:
      - {{ n8n_data_dir }}:/home/node/.n8n
    environment:
      N8N_HOST: "{{ n8n_domain | default('n8n.dev.local') }}"
      N8N_PORT: "5678"
      N8N_PROTOCOL: https
      WEBHOOK_URL: "https://{{ n8n_domain | default('n8n.dev.local') }}/"
      GENERIC_TIMEZONE: "{{ n8n_timezone | default('Europe/Prague') }}"
      TZ: "{{ n8n_timezone | default('Europe/Prague') }}"
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"

{% endif %}
{% if install_kiwix | default(false) %}
  kiwix:
    image: ghcr.io/kiwix/kiwix-serve:latest
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ kiwix_port | default(8888) }}:8080"
{% else %}
      - "127.0.0.1:{{ kiwix_port | default(8888) }}:8080"
{% endif %}
    volumes:
      - {{ kiwix_data_dir }}:/data
    command: /data/*.zim
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

{% endif %}
{% if install_jellyfin | default(false) %}
  jellyfin:
    image: jellyfin/jellyfin:{{ jellyfin_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if jellyfin_lan_access | default(false) or services_lan_access | default(false) %}
      - "{{ jellyfin_port | default(8096) }}:8096"
{% else %}
      - "127.0.0.1:{{ jellyfin_port | default(8096) }}:8096"
{% endif %}
    volumes:
      - {{ jellyfin_config_dir }}:/config
      - {{ jellyfin_cache_dir }}:/cache
      - {{ jellyfin_movies_dir }}:/media/movies:ro
      - {{ jellyfin_shows_dir }}:/media/shows:ro
      - {{ jellyfin_music_dir }}:/media/music:ro
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"

{% endif %}
{% if install_uptime_kuma | default(false) %}
  uptime-kuma:
    image: louislam/uptime-kuma:{{ uptime_kuma_version | default('1') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ uptime_kuma_port | default(3001) }}:3001"
    volumes:
      - {{ uptime_kuma_data_dir }}:/app/data
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

{% endif %}
{% if install_calibreweb | default(false) %}
  calibre-web:
    image: lscr.io/linuxserver/calibre-web:{{ calibreweb_version | default('latest') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ calibreweb_port | default(8083) }}:8083"
    volumes:
      - {{ ansible_facts['env']['HOME'] }}/calibre-web/config:/config
      - {{ calibreweb_books_dir }}:/books
    environment:
      PUID: "{{ ansible_facts['user_uid'] }}"
      PGID: "{{ ansible_facts['user_gid'] }}"
      TZ: "{{ calibreweb_timezone | default('Europe/Prague') }}"
      DOCKER_MODS: linuxserver/mods:universal-calibre
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

{% endif %}
{% if install_openwebui | default(false) %}
  open-webui:
    image: ghcr.io/open-webui/open-webui:{{ openwebui_version | default('main') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ openwebui_port | default(3004) }}:8080"
{% else %}
      - "127.0.0.1:{{ openwebui_port | default(3004) }}:8080"
{% endif %}
    volumes:
      - {{ openwebui_data_dir }}:/app/backend/data
    environment:
      OLLAMA_BASE_URL: "http://host.docker.internal:11434"
      WEBUI_AUTH: "true"
      WEBUI_SECRET_KEY: "{{ openwebui_secret_key | default('changeme_openwebui_secret') }}"
      ENABLE_SIGNUP: "{{ openwebui_enable_signup | default(true) | string | lower }}"
      DEFAULT_USER_ROLE: "user"
      SCARF_NO_ANALYTICS: "true"
      DO_NOT_TRACK: "true"
      ANONYMIZED_TELEMETRY: "false"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"

{% endif %}
{% if install_homeassistant | default(false) %}
  homeassistant:
    image: homeassistant/home-assistant:{{ homeassistant_version | default('stable') }}
    restart: unless-stopped
{% if homeassistant_privileged | default(false) %}
    privileged: true
    network_mode: host
{% else %}
    ports:
      - "127.0.0.1:{{ homeassistant_port | default(8123) }}:8123"
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
{% endif %}
    volumes:
      - {{ homeassistant_config_dir | default(ansible_facts['env']['HOME'] + '/homeassistant') }}:/config
    tmpfs:
      - /tmp
    environment:
      TZ: "{{ homeassistant_timezone | default('Europe/Prague') }}"
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"

{% endif %}
{% if install_rustfs | default(false) %}
  rustfs:
    image: rustfs/rustfs:{{ rustfs_version | default('latest') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ rustfs_api_port | default(9000) }}:9000"
      - "127.0.0.1:{{ rustfs_console_port | default(9001) }}:9001"
    volumes:
      - {{ rustfs_data_dir | default(ansible_facts['env']['HOME'] + '/rustfs/data') }}:/data
    environment:
      RUSTFS_ACCESS_KEY: "{{ rustfs_access_key }}"
      RUSTFS_SECRET_KEY: "{{ rustfs_secret_key }}"
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

{% endif %}
{% if install_offline_maps | default(false) %}
  tileserver:
    image: maptiler/tileserver-gl:latest
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ maps_port | default(8070) }}:8080"
    volumes:
      - {{ maps_data_dir }}:/data
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

{% endif %}

networks:
  iiab_net:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16
  {{ stacks_shared_network }}:
    external: true
