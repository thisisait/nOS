{% if install_portainer | default(false) or install_traefik | default(false) %}
  # ── Docker Socket Proxy – security layer between containers and the Docker API ──
  # Eliminates direct access to docker.sock (container escape vector)
  docker-socket-proxy:
    image: tecnativa/docker-socket-proxy:latest
    restart: unless-stopped
    privileged: true
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      # Read-only API access for Traefik service discovery + Portainer monitoring
      CONTAINERS: 1
      IMAGES: 1
      NETWORKS: 1
      VOLUMES: 1
      SERVICES: 1
      TASKS: 1
      INFO: 1
      EVENTS: 1
      VERSION: 1
      # ── REM-001: trimmed Portainer surface (was: full Swarm + SYSTEM) ────
      # Swarm-related flags (NODES/PLUGINS/SECRETS/CONFIGS/SWARM) and SYSTEM
      # are dropped — nOS does not run Swarm and Portainer's "system info"
      # panel doesn't justify the API surface. Trim closes REM-001's
      # "limit API surface" requirement at zero functional cost for our
      # single-host home-lab use case.
{% if install_portainer | default(false) %}
      POST: 1                                                  # container start/stop/restart
      BUILD: 1                                                 # image build from Dockerfile UI
      # EXEC = container shell. Highest-impact RCE surface if Portainer is
      # compromised (CSRF / XSS / OAuth abuse → docker exec on any container).
      # Operators security-sensitive flip `portainer_socket_proxy_can_exec:
      # false` in config.yml; loses Portainer's web shell, keeps everything else.
      EXEC: {{ 1 if (portainer_socket_proxy_can_exec | default(true)) else 0 }}
      # DISTRIBUTION = registry pull from Portainer UI. Off by default-true;
      # operators who pull images via docker CLI / Ansible only can flip
      # `portainer_socket_proxy_can_distribution: false` to remove the
      # registry-token-leak surface.
      DISTRIBUTION: {{ 1 if (portainer_socket_proxy_can_distribution | default(true)) else 0 }}
{% else %}
      POST: 0
{% endif %}
    networks:
      - infra_net
    logging:
      driver: "json-file"
      options:
        max-size: "5m"
        max-file: "2"
    mem_limit: 128m
    cpus: "0.25"

{% endif %}

