# =============================================================================
# INFRA STACK – sdílené databáze, cache, Portainer, Traefik
# Generováno Ansiblem – NEUPRAVUJ ručně
# =============================================================================

services:

{% if install_mariadb | default(false) %}
  mariadb:
    image: mariadb:{{ mariadb_version | default('lts') }}
    hostname: mariadb
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ mariadb_port | default(3306) }}:3306"
    volumes:
      - {{ mariadb_data_dir | default(ansible_facts['env']['HOME'] + '/mariadb/data') }}:/var/lib/mysql
    environment:
      MARIADB_ROOT_PASSWORD: "{{ mariadb_root_password }}"
      MARIADB_ROOT_HOST: "%"
      MARIADB_CHARACTER_SET_SERVER: utf8mb4
      MARIADB_COLLATION_SERVER: utf8mb4_unicode_ci
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ mariadb_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{% if install_postgresql | default(false) %}
  postgresql:
    image: postgres:{{ postgresql_version | default('16-alpine') }}
    hostname: postgresql
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ postgresql_port | default(5432) }}:5432"
    volumes:
      - {{ postgresql_data_dir | default(ansible_facts['env']['HOME'] + '/postgresql/data') }}:/var/lib/postgresql/data
    environment:
      POSTGRES_PASSWORD: "{{ postgresql_root_password | default(global_password_prefix + '_pw_postgresql') }}"
      POSTGRES_USER: "{{ postgresql_root_user | default('postgres') }}"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgresql_root_user | default('postgres') }}"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 15s
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ postgresql_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{% if redis_docker | default(false) %}
  redis:
    image: redis:{{ redis_version | default('7-alpine') }}
    hostname: redis
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ redis_port | default(6379) }}:6379"
    volumes:
      - {{ redis_data_dir | default(ansible_facts['env']['HOME'] + '/redis/data') }}:/data
    command: redis-server --appendonly yes --maxmemory 256mb --maxmemory-policy allkeys-lru --requirepass {{ redis_password | default(global_password_prefix + '_pw_redis') }}
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "{{ redis_password | default(global_password_prefix + '_pw_redis') }}", "ping"]
      interval: 10s
      timeout: 3s
      retries: 5
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ redis_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ docker_cpus_light | default('0.5') }}

{% endif %}
{% if install_portainer | default(false) or install_traefik | default(false) %}
  # ── Docker Socket Proxy – bezpečnostní vrstva mezi kontejnery a Docker API ──
  # Eliminuje přímý přístup k docker.sock (container escape vektor)
  docker-socket-proxy:
    image: tecnativa/docker-socket-proxy:latest
    restart: unless-stopped
    privileged: true
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      # Read-only API access for Traefik service discovery + Portainer monitoring
      CONTAINERS: 1
      IMAGES: 1
      NETWORKS: 1
      VOLUMES: 1
      SERVICES: 1
      TASKS: 1
      INFO: 1
      EVENTS: 1
      VERSION: 1
      # Portainer needs write access for container management
{% if install_portainer | default(false) %}
      POST: 1
      BUILD: 1
      EXEC: 1
      DISTRIBUTION: 1
      NODES: 1
      PLUGINS: 1
      SECRETS: 1
      CONFIGS: 1
      SWARM: 1
      SYSTEM: 1
{% else %}
      POST: 0
{% endif %}
    networks:
      - infra_net
    logging:
      driver: "json-file"
      options:
        max-size: "5m"
        max-file: "2"
    mem_limit: 128m
    cpus: "0.25"

{% endif %}
{% if install_portainer | default(false) %}
  portainer:
    image: portainer/portainer-ce:{{ portainer_version | default('latest') }}
    restart: unless-stopped
    command: --host tcp://docker-socket-proxy:2375
    depends_on:
      - docker-socket-proxy
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:9000/api/status || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 10
      start_period: 20s
    ports:
{% if services_lan_access | default(false) %}
      - "{{ portainer_port | default(9002) }}:9000"
{% else %}
      - "127.0.0.1:{{ portainer_port | default(9002) }}:9000"
{% endif %}
    volumes:
      - {{ portainer_data_dir }}:/data
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ portainer_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{% if install_traefik | default(false) %}
  traefik:
    image: traefik:{{ traefik_image_version | default('latest') }}
    restart: unless-stopped
    depends_on:
      - docker-socket-proxy
    ports:
{% if not (install_nginx | default(true)) %}
      - "{{ traefik_http_port | default(80) }}:80"
      - "{{ traefik_https_port | default(443) }}:443"
{% endif %}
      - "127.0.0.1:{{ traefik_dashboard_port | default(8080) }}:8080"
    volumes:
      - {{ traefik_config_dir | default(ansible_facts['env']['HOME'] + '/iiab/traefik') }}:/etc/traefik:ro
    environment:
      DOCKER_HOST: "tcp://docker-socket-proxy:2375"
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ traefik_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{% if install_bluesky_pds | default(false) %}
  # ── Bluesky PDS (Personal Data Server) – AT Protocol federace ──────────────
  bluesky-pds:
    image: ghcr.io/bluesky-social/pds:{{ bluesky_pds_version | default('latest') }}
    hostname: bluesky-pds
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ bluesky_pds_port | default(2583) }}:3000"
{% else %}
      - "127.0.0.1:{{ bluesky_pds_port | default(2583) }}:3000"
{% endif %}
    volumes:
      - {{ bluesky_pds_data_dir | default(ansible_facts['env']['HOME'] + '/bluesky-pds') }}:/pds
    environment:
      PDS_HOSTNAME: "{{ bluesky_pds_hostname | default('bsky.dev.lan') }}"
      PDS_JWT_SECRET: "{{ bluesky_pds_jwt_secret }}"
      PDS_ADMIN_PASSWORD: "{{ bluesky_pds_admin_password }}"
      PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX: "{{ bluesky_pds_rotation_key }}"
      PDS_DATA_DIRECTORY: /pds
      PDS_BLOBSTORE_DISK_LOCATION: /pds/blocks
      PDS_DID_PLC_URL: "https://plc.directory"
      PDS_BSKY_APP_VIEW_URL: "https://api.bsky.app"
      PDS_BSKY_APP_VIEW_DID: "did:web:api.bsky.app"
      PDS_REPORT_SERVICE_URL: "https://mod.bsky.app"
      PDS_REPORT_SERVICE_DID: "did:plc:ar7c4by46qjdydhdevvrndac"
      PDS_CRAWLERS: "https://bsky.network"
      PDS_INVITE_REQUIRED: "{{ bluesky_pds_invite_required | default(true) | string | lower }}"
{% if bluesky_pds_email_smtp_url | default('') | length > 0 %}
      PDS_EMAIL_SMTP_URL: "{{ bluesky_pds_email_smtp_url }}"
      PDS_EMAIL_FROM_ADDRESS: "{{ bluesky_pds_email_from | default('noreply@' ~ bluesky_pds_hostname) }}"
{% endif %}
      LOG_ENABLED: "true"
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:3000/xrpc/_health || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 10
      start_period: 10s
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ bluesky_pds_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ docker_cpus_light | default('0.5') }}

{% endif %}
{% if install_authentik | default(false) %}
  # ── Authentik – SSO / Identity Provider ──────────────────────────────────────
  authentik-server:
    image: ghcr.io/goauthentik/server:{{ authentik_version | default('2025.2') }}
    command: server
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ authentik_port | default(9000) }}:9000"
{% else %}
      - "127.0.0.1:{{ authentik_port | default(9000) }}:9000"
{% endif %}
    volumes:
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/media:/media
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/templates:/templates
      - {{ stacks_dir }}/infra/authentik/blueprints:/blueprints/custom:ro
    environment:
      AUTHENTIK_SECRET_KEY: "{{ authentik_secret_key }}"
      AUTHENTIK_REDIS__HOST: redis
      AUTHENTIK_REDIS__PASSWORD: "{{ redis_password | default(global_password_prefix + '_pw_redis') }}"
      AUTHENTIK_POSTGRESQL__HOST: postgresql
      AUTHENTIK_POSTGRESQL__USER: "{{ authentik_db_user | default('authentik') }}"
      AUTHENTIK_POSTGRESQL__NAME: "{{ authentik_db_name | default('authentik') }}"
      AUTHENTIK_POSTGRESQL__PASSWORD: "{{ authentik_db_password }}"
      AUTHENTIK_BOOTSTRAP_PASSWORD: "{{ authentik_bootstrap_password }}"
      AUTHENTIK_BOOTSTRAP_EMAIL: "{{ authentik_bootstrap_email | default(default_admin_email) }}"
      AUTHENTIK_ERROR_REPORTING__ENABLED: "false"
      AUTHENTIK_DISABLE_STARTUP_ANALYTICS: "true"
      AUTHENTIK_COOKIE_DOMAIN: ".{{ instance_tld | default('dev.local') }}"
      AUTHENTIK_HOST: "https://{{ authentik_domain | default('auth.dev.local') }}"
      AUTHENTIK_HOST_BROWSER: "https://{{ authentik_domain | default('auth.dev.local') }}"
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ authentik_mem_limit | default(docker_mem_limit_critical) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

  authentik-worker:
    image: ghcr.io/goauthentik/server:{{ authentik_version | default('2025.2') }}
    command: worker
    restart: unless-stopped
    volumes:
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/media:/media
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/templates:/templates
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/certs:/certs
      - {{ stacks_dir }}/infra/authentik/blueprints:/blueprints/custom:ro
    environment:
      AUTHENTIK_SECRET_KEY: "{{ authentik_secret_key }}"
      AUTHENTIK_REDIS__HOST: redis
      AUTHENTIK_REDIS__PASSWORD: "{{ redis_password | default(global_password_prefix + '_pw_redis') }}"
      AUTHENTIK_POSTGRESQL__HOST: postgresql
      AUTHENTIK_POSTGRESQL__USER: "{{ authentik_db_user | default('authentik') }}"
      AUTHENTIK_POSTGRESQL__NAME: "{{ authentik_db_name | default('authentik') }}"
      AUTHENTIK_POSTGRESQL__PASSWORD: "{{ authentik_db_password }}"
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ authentik_worker_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}
{% if install_infisical | default(false) %}
  # ── Infisical CE – Secrets Vault ─────────────────────────────────────────────
  infisical:
    image: infisical/infisical:{{ infisical_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ infisical_port | default(8075) }}:8080"
{% else %}
      - "127.0.0.1:{{ infisical_port | default(8075) }}:8080"
{% endif %}
    volumes:
      - {{ infisical_data_dir | default(ansible_facts['env']['HOME'] + '/infisical') }}:/app/data
    environment:
      ENCRYPTION_KEY: "{{ infisical_encryption_key }}"
      AUTH_SECRET: "{{ infisical_auth_secret }}"
      DB_CONNECTION_URI: "postgresql://{{ infisical_db_user | default('infisical') }}:{{ infisical_db_password }}@postgresql:5432/{{ infisical_db_name | default('infisical') }}"
      REDIS_URL: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379"
      SITE_URL: "https://{{ infisical_domain | default('vault.dev.local') }}"
      TELEMETRY_ENABLED: "false"
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ infisical_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{% endif %}

networks:
  infra_net:
    driver: bridge
  {{ stacks_shared_network }}:
    external: true
