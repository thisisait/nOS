services:

{# mariadb service byl extrahovany do role pazny.mariadb (Wave 2.1) a
   renderuje se do {{ stacks_dir }}/infra/overrides/mariadb.yml. core-up.yml
   ho merguje pres `docker compose -f base.yml -f overrides/mariadb.yml up`. #}

{# postgresql service byl extrahovany do role pazny.postgresql (Wave 2.2) a
   renderuje se do {{ stacks_dir }}/infra/overrides/postgresql.yml. core-up.yml
   ho merguje stejnym zpusobem. Install gate: install_postgresql. #}

{# redis service byl extrahovany do role pazny.redis (Wave 2.2) a renderuje
   se do {{ stacks_dir }}/infra/overrides/redis.yml. core-up.yml ho merguje
   stejnym zpusobem. Install gate: redis_docker (ne install_redis — kvuli
   koexistenci s Homebrew Redis). #}

{% if install_portainer | default(false) or install_traefik | default(false) %}
  # ── Docker Socket Proxy – bezpečnostní vrstva mezi kontejnery a Docker API ──
  # Eliminuje přímý přístup k docker.sock (container escape vektor)
  docker-socket-proxy:
    image: tecnativa/docker-socket-proxy:latest
    restart: unless-stopped
    privileged: true
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      # Read-only API access for Traefik service discovery + Portainer monitoring
      CONTAINERS: 1
      IMAGES: 1
      NETWORKS: 1
      VOLUMES: 1
      SERVICES: 1
      TASKS: 1
      INFO: 1
      EVENTS: 1
      VERSION: 1
      # Portainer needs write access for container management
{% if install_portainer | default(false) %}
      POST: 1
      BUILD: 1
      EXEC: 1
      DISTRIBUTION: 1
      NODES: 1
      PLUGINS: 1
      SECRETS: 1
      CONFIGS: 1
      SWARM: 1
      SYSTEM: 1
{% else %}
      POST: 0
{% endif %}
    networks:
      - infra_net
    logging:
      driver: "json-file"
      options:
        max-size: "5m"
        max-file: "2"
    mem_limit: 128m
    cpus: "0.25"

{% endif %}

{# portainer service byl extrahovany do role pazny.portainer (Wave 2.2)
   a renderuje se do {{ stacks_dir }}/infra/overrides/portainer.yml.
   core-up.yml ho merguje pres `docker compose -f base.yml -f overrides/portainer.yml up`. #}

{# traefik service byl extrahovany do role pazny.traefik (Wave 2.2)
