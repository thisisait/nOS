{% if install_portainer | default(false) or install_traefik | default(false) %}
  # ── Docker Socket Proxy – security layer between containers and the Docker API ──
  # Eliminates direct access to docker.sock (container escape vector)
  docker-socket-proxy:
    image: tecnativa/docker-socket-proxy:latest
    restart: unless-stopped
    privileged: true
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      # Read-only API access for Traefik service discovery + Portainer monitoring
      CONTAINERS: 1
      IMAGES: 1
      NETWORKS: 1
      VOLUMES: 1
      SERVICES: 1
      TASKS: 1
      INFO: 1
      EVENTS: 1
      VERSION: 1
      # Portainer needs write access for container management
{% if install_portainer | default(false) %}
      POST: 1
      BUILD: 1
      EXEC: 1
      DISTRIBUTION: 1
      NODES: 1
      PLUGINS: 1
      SECRETS: 1
      CONFIGS: 1
      SWARM: 1
      SYSTEM: 1
{% else %}
      POST: 0
{% endif %}
    networks:
      - infra_net
    logging:
      driver: "json-file"
      options:
        max-size: "5m"
        max-file: "2"
    mem_limit: 128m
    cpus: "0.25"

{% endif %}

