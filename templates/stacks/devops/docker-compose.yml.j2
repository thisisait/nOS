# =============================================================================
# DEVOPS STACK – Gitea, Woodpecker CI, GitLab, Paperclip
# Generováno Ansiblem – NEUPRAVUJ ručně
#
# Wave 2.2 Unit 10: všechny services byly extrahované do dedikovaných rolí.
# Tento base soubor drží už jen networks: — actual service bloky přidávají
# role-specific overrides v {{ stacks_dir }}/devops/overrides/*.yml, které
# stack-up.yml sbírá přes `find + -f` merge loop.
#
# Mapa fragmentů:
#   • gitea       → roles/pazny.gitea/templates/compose.yml.j2
#   • woodpecker  → roles/pazny.woodpecker/templates/compose.yml.j2 (server + agent)
#   • gitlab      → roles/pazny.gitlab/templates/compose.yml.j2
#   • paperclip   → roles/pazny.paperclip/templates/compose.yml.j2
#
# Prázdný services: dict by docker compose odmítl, takže deklarujeme placeholder
# přes explicit {} — overrides ho pak rozšíří o reálné services.
# =============================================================================

services: {}

networks:
  devops_net:
    driver: bridge
  {{ stacks_shared_network }}:
    external: true
