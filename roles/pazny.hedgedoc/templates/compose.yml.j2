# =============================================================================
# pazny.hedgedoc — compose override fragment
# Merged do `docker compose up` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/b2b/overrides/*.yml.
#
# Neredeklaruje top-level networks: — b2b_net a {{ stacks_shared_network }}
# jsou definovane v base templates/stacks/b2b/docker-compose.yml.j2.
#
# HedgeDoc vyzaduje: PostgreSQL (z infra stacku).
#
# D2 (2026-05-05): CMD_OAUTH2_* env vars + mkcert CA volume + authentik
# extra_host MOVED to hedgedoc-base plugin's compose-extension (files/anatomy/
# plugins/hedgedoc-base/templates/hedgedoc-base.compose.yml.j2). Role keeps
# install-only concerns: DB, session, SMTP relay, mailpit extra_host.
# Config reference: https://docs.hedgedoc.org/configuration/
# =============================================================================

services:
  hedgedoc:
    image: quay.io/hedgedoc/hedgedoc:{{ hedgedoc_version | default('1.10.7') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ hedgedoc_port | default(3012) }}:3000"
{% else %}
      - "127.0.0.1:{{ hedgedoc_port | default(3012) }}:3000"
{% endif %}
    volumes:
      - {{ hedgedoc_data_dir | default(ansible_facts['env']['HOME'] + '/hedgedoc/uploads') }}:/hedgedoc/public/uploads
{# mkcert CA volume + Authentik extra_host moved to hedgedoc-base plugin (D2). #}
    environment:
      # ── Database (PostgreSQL z infra stacku) ──────────────────────────────
      CMD_DB_URL: "postgres://{{ hedgedoc_db_user | default('hedgedoc') }}:{{ hedgedoc_db_password | default(global_password_prefix + '_pw_hedgedoc') }}@postgresql:5432/{{ hedgedoc_db_name | default('hedgedoc') }}"
      # ── Public URL / protocol ──────────────────────────────────────────────
      CMD_DOMAIN: "{{ hedgedoc_domain | default('hedgedoc' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
      CMD_URL_ADDPORT: "false"
      CMD_PROTOCOL_USESSL: "true"
      CMD_HOST: "0.0.0.0"
      CMD_PORT: "3000"
      # ── Session ─────────────────────────────────────────────────────────────
      CMD_SESSION_SECRET: "{{ hedgedoc_session_secret | default(global_password_prefix + '_pw_hedgedoc_session') }}"
      # ── Auth policy (OIDC only — no anonymous / email register) ───────────
      CMD_ALLOW_ANONYMOUS: "false"
      CMD_ALLOW_EMAIL_REGISTER: "false"
      # ── CDN / uploads ──────────────────────────────────────────────────────
      CMD_USECDN: "false"
      CMD_UPLOADS_PATH: "/hedgedoc/public/uploads"
{# CMD_OAUTH2_* env + NODE_EXTRA_CA_CERTS moved to hedgedoc-base plugin (D2 2026-05-05). #}
{% if install_mailpit | default(false) %}
      # ── SMTP relay → Mailpit (dev mail capture) ────────────────────────────
      # Mailpit lives on iiab_net only; reach it via host-gateway.
      CMD_EMAIL: "true"
      CMD_SMTP_HOST: "host.docker.internal"
      CMD_SMTP_PORT: "1025"
      CMD_SMTP_SECURE: "false"
      CMD_SMTP_FROM: "hedgedoc@{{ tenant_domain | default('dev.local') }}"
{% endif %}
{% if install_mailpit | default(false) %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
{# authentik extra_host moved to hedgedoc-base plugin compose-extension (D2). #}
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ hedgedoc_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ hedgedoc_cpus | default(docker_cpus_standard | default('1.0')) }}
