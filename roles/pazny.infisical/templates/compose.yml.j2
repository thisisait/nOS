# =============================================================================
# pazny.infisical — compose override fragment
# Merged do `docker compose -p infra up` v tasks/stacks/core-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/infra/overrides/*.yml.
# =============================================================================

services:
  # ── Infisical CE – Secrets Vault ─────────────────────────────────────────────
  infisical:
    image: infisical/infisical:{{ infisical_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ infisical_port | default(8075) }}:8080"
{% else %}
      - "127.0.0.1:{{ infisical_port | default(8075) }}:8080"
{% endif %}
    volumes:
      - {{ infisical_data_dir | default(ansible_facts['env']['HOME'] + '/infisical') }}:/app/data
    environment:
      ENCRYPTION_KEY: "{{ infisical_encryption_key }}"
      AUTH_SECRET: "{{ infisical_auth_secret }}"
      DB_CONNECTION_URI: "postgresql://{{ infisical_db_user | default('infisical') }}:{{ infisical_db_password }}@postgresql:5432/{{ infisical_db_name | default('infisical') }}"
      REDIS_URL: "redis://:{{ redis_password | default(global_password_prefix + '_pw_redis') }}@redis:6379"
      SITE_URL: "https://{{ infisical_domain | default('vault' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
      TELEMETRY_ENABLED: "false"
{# OIDC_CLIENT_ID/SECRET/DISCOVERY/ISSUER/REDIRECT_URI moved to infisical-base plugin (D2 2026-05-05). #}
{% if install_mailpit | default(false) %}
      # ── SMTP relay → Mailpit (dev mail capture) ────────────────────────────
      # Mailpit lives on iiab_net only; reach it via host-gateway.
      SMTP_HOST: "host.docker.internal"
      SMTP_PORT: "1025"
      SMTP_USERNAME: ""
      SMTP_PASSWORD: ""
      SMTP_FROM_ADDRESS: "infisical@{{ tenant_domain | default('dev.local') }}"
      SMTP_FROM_NAME: "Infisical"
{% endif %}
{% if install_mailpit | default(false) %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
{# authentik extra_host moved to infisical-base plugin compose-extension (D2). #}
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ infisical_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
