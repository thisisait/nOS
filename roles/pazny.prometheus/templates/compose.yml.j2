# =============================================================================
# pazny.prometheus — compose override fragment
# Merged do `docker compose -p observability up` v tasks/stacks/core-up.yml
# pres ansible.builtin.find nad {{ stacks_dir }}/observability/overrides/*.yml.
#
# Nedeklaruje top-level networks: — observability_net a
# {{ stacks_shared_network }} jsou definovane v base
# templates/stacks/observability/docker-compose.yml.j2.
#
# prometheus.yml konfig zustava renderovany v core-up.yml do
# {{ stacks_dir }}/observability/prometheus/prometheus.yml — bind mount
# nize ho naveze do kontejneru read-only.
# =============================================================================

services:
  prometheus:
    image: prom/prometheus:{{ prometheus_version | default('latest') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ prometheus_port | default(9090) }}:9090"
    volumes:
      - {{ stacks_dir }}/observability/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ prometheus_storage_path | default(stacks_dir + '/observability/prometheus/data') }}:/prometheus
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ prometheus_retention | default('30d') }}"
      - "--web.enable-remote-write-receiver"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:9090/-/ready || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - observability_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ prometheus_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ prometheus_cpus | default(docker_cpus_standard | default('1.0')) }}
