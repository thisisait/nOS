# =============================================================================
# pazny.n8n — compose override fragment
# Merged do `docker compose -p iiab up` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/iiab/overrides/*.yml.
# =============================================================================

services:
  n8n:
    image: n8nio/n8n:{{ n8n_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ n8n_port | default(5678) }}:5678"
{% else %}
      - "127.0.0.1:{{ n8n_port | default(5678) }}:5678"
{% endif %}
    volumes:
      - {{ n8n_data_dir }}:/home/node/.n8n
{# mkcert CA volume + NODE_EXTRA_CA_CERTS + Authentik env moved to n8n-base plugin (D2). #}
    environment:
      N8N_HOST: "{{ n8n_domain | default('n8n' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
      N8N_PORT: "5678"
      N8N_PROTOCOL: https
      WEBHOOK_URL: "https://{{ n8n_domain | default('n8n' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/"
      GENERIC_TIMEZONE: "{{ n8n_timezone | default('Europe/Prague') }}"
      TZ: "{{ n8n_timezone | default('Europe/Prague') }}"
{# N8N_AUTH_OIDC_* + NODE_EXTRA_CA_CERTS moved to n8n-base plugin compose-extension (D2 2026-05-05). #}
{% if install_mailpit | default(false) %}
      # ── SMTP relay → Mailpit (dev mail capture) ────────────────────────────
      N8N_EMAIL_MODE: "smtp"
      N8N_SMTP_HOST: "mailpit"
      N8N_SMTP_PORT: "1025"
      N8N_SMTP_SENDER: "n8n@{{ tenant_domain | default('dev.local') }}"
      N8N_SMTP_SSL: "false"
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:5678/healthz || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
{# authentik extra_host moved to n8n-base plugin compose-extension (D2). #}
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ n8n_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
