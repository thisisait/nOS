# =============================================================================
# pazny.firefly — compose override fragment
# Merged into `docker compose -p b2b up` by tasks/stacks/stack-up.yml via
# ansible.builtin.find across {{ stacks_dir }}/b2b/overrides/*.yml.
#
# Does not declare top-level networks: — b2b_net and {{ stacks_shared_network }}
# are defined in base templates/stacks/b2b/docker-compose.yml.j2.
#
# Firefly III requires: MariaDB + Redis (both from the infra stack).
# SSO: remote_user_guard — Authentik proxy outpost via nginx auth_request,
# Firefly receives REMOTE_USER + REMOTE_EMAIL headers and auto-creates accounts.
# =============================================================================

services:
  firefly:
    image: fireflyiii/core:{{ firefly_version | default('version-6.2.21') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ firefly_port | default(3014) }}:8080"
{% else %}
      - "127.0.0.1:{{ firefly_port | default(3014) }}:8080"
{% endif %}
    volumes:
      - {{ firefly_upload_dir }}:/var/www/html/storage/upload
      - {{ firefly_export_dir }}:/var/www/html/storage/export
    environment:
      APP_ENV: "production"
      APP_DEBUG: "false"
      APP_KEY: "{{ firefly_app_key }}"
      SITE_OWNER: "{{ firefly_site_owner | default(default_admin_email) }}"
      APP_URL: "https://{{ firefly_domain | default('firefly.dev.local') }}"
      TRUSTED_PROXIES: "**"
      TZ: "{{ firefly_tz | default('Europe/Prague') }}"
      DEFAULT_LANGUAGE: "{{ firefly_default_language | default('en_US') }}"
      LOG_CHANNEL: "stack"
      APP_LOG_LEVEL: "notice"
      AUDIT_LOG_LEVEL: "emergency"
      # ── Database (MariaDB z infra stacku) ─────────────────────────────────
      DB_CONNECTION: "mysql"
      DB_HOST: "{% if install_mariadb | default(false) %}mariadb{% else %}{{ firefly_db_host | default('127.0.0.1') }}{% endif %}"
      DB_PORT: "3306"
      DB_DATABASE: "{{ firefly_db_name }}"
      DB_USERNAME: "{{ firefly_db_user }}"
      DB_PASSWORD: "{{ firefly_db_password }}"
      MYSQL_USE_SSL: "false"
      # ── Cache / session (Redis z infra stacku) ────────────────────────────
      CACHE_DRIVER: "redis"
      SESSION_DRIVER: "redis"
      REDIS_HOST: "redis"
      REDIS_PASSWORD: "{{ redis_password | default(global_password_prefix + '_pw_redis') }}"
      REDIS_PORT: "6379"
{% if install_authentik | default(false) %}
      # ── Authentik SSO (remote_user_guard via nginx auth_request) ─────────
      # Firefly reads REMOTE_USER and REMOTE_EMAIL headers set by nginx after a
      # successful Authentik proxy-outpost authentication. Auto-creates user
      # on first login.
      AUTHENTICATION_GUARD: "remote_user_guard"
      AUTHENTICATION_GUARD_HEADER: "REMOTE_USER"
      AUTHENTICATION_GUARD_EMAIL: "REMOTE_EMAIL"
{% endif %}
    # /health is Firefly's own Laravel route and only returns 200 once schema
    # is migrated AND redis is reachable. Print the HTTP status via curl -w so
    # failing probes show the actual code in `docker inspect`'s Health.Log
    # (the previous `-s -o /dev/null` hid the reason).
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS -o /dev/null -w '%{http_code}' http://127.0.0.1:8080/health | grep -q '^200$' || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 180s      # up from 90s; first-boot migrations on a slow MariaDB can take 60-120s
{% if install_authentik | default(false) %}
    extra_hosts:
      - "{{ authentik_domain | default('auth.dev.local') }}:host-gateway"
{% endif %}
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ firefly_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ firefly_cpus | default(docker_cpus_standard | default('1.0')) }}
