# =============================================================================
# pazny.rustfs — compose override fragment
# Merged into `docker compose up iiab` by tasks/stacks/stack-up.yml via
# ansible.builtin.find across {{ stacks_dir }}/iiab/overrides/*.yml.
#
# Does not declare top-level networks: — iiab_net and {{ stacks_shared_network }}
# are defined in base templates/stacks/iiab/docker-compose.yml.j2.
# =============================================================================

services:
  rustfs:
    image: rustfs/rustfs:{{ rustfs_version | default('latest') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ rustfs_api_port | default(9010) }}:9000"
      - "127.0.0.1:{{ rustfs_console_port | default(9001) }}:9001"
    volumes:
      - {{ rustfs_data_dir | default(ansible_facts['env']['HOME'] + '/rustfs/data') }}:/data
    environment:
      RUSTFS_ACCESS_KEY: "{{ rustfs_access_key }}"
      RUSTFS_SECRET_KEY: "{{ rustfs_secret_key }}"
    healthcheck:
      test: ["CMD-SHELL", "wget -q -O /dev/null http://127.0.0.1:9000/minio/health/live 2>&1 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ rustfs_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ docker_cpus_light | default('0.5') }}
