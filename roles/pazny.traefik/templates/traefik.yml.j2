# {{ ansible_managed }}
# Traefik static configuration — rendered by pazny.traefik. Edge proxy.

api:
  dashboard: true
  # `insecure: true` exposes the dashboard on Traefik's built-in "traefik"
  # entry point (port 8080 inside the container). We don't define a separate
  # `dashboard` entry point — that would collide with the built-in one.
  # The compose override binds host 127.0.0.1:{{ traefik_dashboard_port }} →
  # container :8080 so the dashboard stays local-only.
  insecure: true

global:
  checkNewVersion: false
  sendAnonymousUsage: false

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true
  websecure:
    address: ":443"
    http:
      tls:
        options: "modern@file"

providers:
  docker:
    # Tier-2 apps (apps_runner) + any future labelled containers.
    exposedByDefault: false
    network: "{{ stacks_shared_network | default('shared_net') }}"
    endpoint: "tcp://docker-socket-proxy:2375"
    watch: true
  file:
    # Tier-1 services (existing pazny.* roles) — services.yml, middlewares.yml,
    # tls.yml rendered by tasks/main.yml. Watch=true → hot-reload on change.
    directory: "/etc/traefik/conf.d"
    watch: true

log:
  level: "{{ traefik_log_level | default('INFO') }}"
  filePath: "/var/log/traefik/traefik.log"
  format: "json"

accessLog:
  filePath: "/var/log/traefik/access.log"
  format: "json"
  bufferingSize: 100

# Liveness endpoint for the docker healthcheck — exposed on the same built-in
# "traefik" entry point as the dashboard (i.e. container port 8080).
ping: {}
