# {{ ansible_managed }}
# Traefik FILE-PROVIDER middlewares — Authentik forward-auth + security headers.
# Equivalent of the legacy nginx authentik-proxy-locations.conf snippet.

http:
  middlewares:
    # ── Authentik forward-auth ────────────────────────────────────────────
    # The embedded outpost lives on host 127.0.0.1:{{ authentik_port | default(9003) }}
    # — Traefik reaches it via the nos-host extra_hosts alias. Fail-closed:
    # if the outpost is unreachable, Traefik returns 502 (no auth bypass —
    # PENTEST-002 posture preserved).
    authentik:
      forwardAuth:
        address: "http://nos-host:{{ authentik_port | default(9003) }}/outpost.goauthentik.io/auth/traefik"
        trustForwardHeader: true
        authResponseHeaders:
          - X-authentik-username
          - X-authentik-uid
          - X-authentik-email
          - X-authentik-name
          - X-authentik-groups
          - X-authentik-meta-app
          - X-authentik-meta-jwks
          - X-authentik-meta-outpost
          - X-authentik-meta-provider
          - X-authentik-meta-version

    # ── Security baseline (HSTS, sniff, frame, referrer) ──────────────────
    security-headers:
      headers:
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        stsPreload: false
        contentTypeNosniff: true
        browserXssFilter: true
        referrerPolicy: "same-origin"
        frameDeny: false   # apps that legitimately frame each other (Outline embeds, OnlyOffice) need iframe support

    # ── HTTPS redirect (already global at entry-point level; kept here for explicit per-router opt-in) ─
    https-redirect:
      redirectScheme:
        scheme: https
        permanent: true

    # ── Compression ───────────────────────────────────────────────────────
    compress:
      compress: {}

  # ── Servers transports ────────────────────────────────────────────────
  serversTransports:
    # Skip cert verify for upstream HTTPS — used when reaching Authentik or
    # other services that present a self-signed dev cert. Tier-1 routers
    # default to HTTP upstream so this is rarely needed; available as opt-in.
    insecure-skip:
      insecureSkipVerify: true

# ── TLS options ─────────────────────────────────────────────────────────
tls:
  options:
    modern:
      minVersion: "VersionTLS13"
      sniStrict: false
    default:
      minVersion: "VersionTLS12"
      cipherSuites:
        - "TLS_AES_128_GCM_SHA256"
        - "TLS_AES_256_GCM_SHA384"
        - "TLS_CHACHA20_POLY1305_SHA256"
        - "TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256"
        - "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256"
        - "TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305"
        - "TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305"
