# =============================================================================
# pazny.traefik — compose override fragment (PRIMARY edge proxy).
# Big-Bang cutover 2026-04-27: binds 80/443 unconditionally; host nginx is
# opt-in fallback (install_nginx) and runs alongside on alternative ports
# only when explicitly enabled.
#
# Networks: joins infra_net (Authentik etc.) + shared_net (Tier-2 apps via
# Docker provider). Adds nos-host:host-gateway alias so file-provider routers
# can reach services published on host loopback (127.0.0.1:<port>).
# =============================================================================

services:
  traefik:
    image: traefik:{{ traefik_image_version | default('v3.6.12') }}
    restart: unless-stopped
    depends_on:
      - docker-socket-proxy
    ports:
      # Edge — public on every interface
      - "{{ traefik_http_port | default(80) }}:80"
      - "{{ traefik_https_port | default(443) }}:443"
      # Dashboard + ping — local only (api.insecure: true is fine since 127.0.0.1)
      - "127.0.0.1:{{ traefik_dashboard_port | default(8080) }}:8080"
    volumes:
      # Static config (traefik.yml) + dynamic config tree (conf.d/)
      - {{ traefik_config_dir }}:/etc/traefik:ro
      # Cert tree — bind read-only; mkcert + ACME write here from the host.
      - {{ traefik_certs_dir }}:/certs:ro
      # Logs (host-readable for tailing + Alloy scrape)
      - {{ traefik_log_dir }}:/var/log/traefik:rw
    environment:
      DOCKER_HOST: "tcp://docker-socket-proxy:2375"
    networks:
{% for net in (traefik_networks | default(['infra_net', stacks_shared_network | default('shared_net')])) %}
      - {{ net }}
{% endfor %}
    extra_hosts:
      # Cross-platform host loopback alias — file-provider routers use
      # http://nos-host:<port> for every Tier-1 upstream because nOS Docker
      # services publish their primary port via 127.0.0.1:<port>:<int>.
      - "nos-host:host-gateway"
      - "host.docker.internal:host-gateway"
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ traefik_mem_limit | default(docker_mem_limit_standard | default('1g')) }}
    cpus: {{ traefik_cpus | default(docker_cpus_standard | default('1.0')) }}
    healthcheck:
      # Dashboard ping endpoint — wget present in alpine variant.
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:8080/ping"]
      interval: 30s
      timeout: 5s
      start_period: 15s
      retries: 3
