# =============================================================================
# pazny.open_webui — compose override fragment
# Merged do `docker compose up iiab` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/iiab/overrides/*.yml.
#
# Nedeklaruje top-level networks: — iiab_net a {{ stacks_shared_network }}
# jsou definovane v base templates/stacks/iiab/docker-compose.yml.j2.
# =============================================================================

services:
  open-webui:
    image: ghcr.io/open-webui/open-webui:{{ openwebui_version | default('main') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ openwebui_port | default(3004) }}:8080"
{% else %}
      - "127.0.0.1:{{ openwebui_port | default(3004) }}:8080"
{% endif %}
    volumes:
      - {{ openwebui_data_dir }}:/app/backend/data
{% if tenant_domain_is_local | default(true) | bool %}
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/usr/local/share/ca-certificates/mkcert-ca.crt:ro
{% endif %}
    environment:
      OLLAMA_BASE_URL: "http://host.docker.internal:11434"
      WEBUI_AUTH: "true"
      WEBUI_SECRET_KEY: "{{ openwebui_secret_key | default(global_password_prefix + '_pw_openwebui') }}"
      ENABLE_SIGNUP: "{{ openwebui_enable_signup | default(true) | string | lower }}"
      DEFAULT_USER_ROLE: "user"
      SCARF_NO_ANALYTICS: "true"
      DO_NOT_TRACK: "true"
      ANONYMIZED_TELEMETRY: "false"
{% if tenant_domain_is_local | default(true) | bool %}
      # On a local TLD (.local/.lan/.test) the only TLS cert in play is the
      # mkcert one — point the bundle at it. On a public TLD we must NOT set
      # this, otherwise Python httpx + Open WebUI can't validate LE certs
      # against the system root store (the mkcert-only bundle would shadow
      # the Mozilla CA list). Surfaced 2026-05-03 against auth.pazny.eu.
      REQUESTS_CA_BUNDLE: "/usr/local/share/ca-certificates/mkcert-ca.crt"
      SSL_CERT_FILE: "/usr/local/share/ca-certificates/mkcert-ca.crt"
      # ── MCP: akceptovat self-signed certy (mkcert) pri volani MCP serveru ──
      AIOHTTP_CLIENT_SESSION_TOOL_SERVER_SSL: "/usr/local/share/ca-certificates/mkcert-ca.crt"
{% endif %}
      # ── MCP: forward user identity + chat ID to MCP servers (0.8.0+) ───────
      # Umoznuje per-user auth a attribution pri volani MCP toolu.
      ENABLE_FORWARD_USER_INFO_HEADERS: "true"
{% if install_mcp_gateway | default(false) %}
      # ── Auto-registrace mcpo MCP gateway jako tool server ──────────────────
      # OpenWebUI 0.8.x: TOOL_SERVER_CONNECTIONS se nacte pri prvnim startu
      # a ulozi do DB. Potom editovatelne v Admin → Settings → Tools.
      TOOL_SERVER_CONNECTIONS: >-
        [{"url":"http://mcpo:8000","path":"openapi.json","auth_type":"bearer","key":"{{ mcpo_api_key }}","config":{"enable":true}}]
      USER_PERMISSIONS_FEATURES_DIRECT_TOOL_SERVERS: "true"
{% endif %}
{% if anthropic_api_key is defined and (anthropic_api_key | length) > 0 %}
      # ── Anthropic Claude konektor (OpenAI-compat endpoint) ─────────────────
      # Pristup k claude-opus/sonnet pres native OpenAI-compatible API.
      # Multi-provider: drzi puvodni OpenAI + pridava Anthropic vedle.
      OPENAI_API_BASE_URLS: "https://api.openai.com/v1;https://api.anthropic.com/v1"
      OPENAI_API_KEYS: "{{ openai_api_key | default('sk-placeholder') }};{{ anthropic_api_key }}"
      ENABLE_OPENAI_API: "true"
{% endif %}
{% if install_authentik | default(false) %}
      # ── Authentik SSO (OIDC) ───────────────────────────────────────────────
      ENABLE_OAUTH_SIGNUP: "true"
      OAUTH_PROVIDER_NAME: "Authentik"
      OAUTH_CLIENT_ID: "{{ authentik_oidc_openwebui_client_id }}"
      OAUTH_CLIENT_SECRET: "{{ authentik_oidc_openwebui_client_secret }}"
      OPENID_PROVIDER_URL: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/application/o/open-webui/.well-known/openid-configuration"
      OAUTH_MERGE_ACCOUNTS_BY_EMAIL: "true"
      OAUTH_SCOPES: "openid profile email"
{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8080/api/config"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 60s
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% if install_authentik | default(false) %}
      - "{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}:host-gateway"
{% endif %}
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ openwebui_mem_limit | default(docker_mem_limit_critical) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
