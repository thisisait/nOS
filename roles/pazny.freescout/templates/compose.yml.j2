# =============================================================================
# pazny.freescout — compose override fragment
# Merged into `docker compose up` in tasks/stacks/stack-up.yml via
# ansible.builtin.find over {{ stacks_dir }}/b2b/overrides/*.yml.
#
# Does NOT redeclare top-level networks: — b2b_net and {{ stacks_shared_network }}
# are defined in the base templates/stacks/b2b/docker-compose.yml.j2.
#
# FreeScout requires: MariaDB (from the infra stack, database + user created
# by default.config.yml mariadb_databases / mariadb_users seed lists).
#
# Native OIDC (Authentik) is wired via the `freescout-oauth` community module
# that is installed + enabled in tasks/post.yml. The env vars below are read
# by that module when present; they are also used by our post.yml to seed the
# oauth_module DB rows so the end-user does not have to fill in the UI form.
# =============================================================================

services:
  freescout:
    image: tiredofit/freescout:{{ freescout_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ freescout_port | default(8090) }}:80"
{% else %}
      - "127.0.0.1:{{ freescout_port | default(8090) }}:80"
{% endif %}
    volumes:
      - {{ freescout_data_dir | default(ansible_facts['env']['HOME'] + '/freescout/data') }}:/data
{% if install_authentik | default(false) %}
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/usr/local/share/ca-certificates/mkcert-ca.crt:ro
{% endif %}
    environment:
      CONTAINER_NAME: freescout
      DB_HOST: mariadb
      DB_PORT: "3306"
      DB_NAME: "{{ freescout_db_name | default('freescout') }}"
      DB_USER: "{{ freescout_db_user | default('freescout') }}"
      DB_PASS: "{{ freescout_db_password | default(global_password_prefix + '_pw_freescout') }}"
      SITE_URL: "https://{{ freescout_domain | default('helpdesk.dev.local') }}"
      ADMIN_EMAIL: "{{ freescout_admin_email | default(default_admin_email) }}"
      ADMIN_PASS: "{{ freescout_admin_password | default(global_password_prefix + '_pw_freescout') }}"
      TIMEZONE: "{{ freescout_timezone | default('Europe/Prague') }}"
      ENABLE_SSL_PROXY: "TRUE"
{% if install_authentik | default(false) %}
      # ── Authentik SSO (OIDC via freescout-oauth module) ───────────────────
      # These are read by the freescout-oauth module on bootstrap; the post.yml
      # also persists them into the module's DB settings for headless install.
      FREESCOUT_OIDC_ENABLED: "true"
      FREESCOUT_OIDC_DISCOVERY: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/freescout/.well-known/openid-configuration"
      FREESCOUT_OIDC_CLIENT_ID: "{{ authentik_oidc_freescout_client_id | default('nos-freescout') }}"
      FREESCOUT_OIDC_CLIENT_SECRET: "{{ authentik_oidc_freescout_client_secret | default(global_password_prefix + '_pw_oidc_freescout') }}"
      FREESCOUT_OIDC_REDIRECT_URI: "https://{{ freescout_domain | default('helpdesk.dev.local') }}/oauth/callback"
      FREESCOUT_OIDC_SCOPES: "openid profile email"
      FREESCOUT_OIDC_AUTHORIZE_URL: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/authorize/"
      FREESCOUT_OIDC_TOKEN_URL: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/token/"
      FREESCOUT_OIDC_USERINFO_URL: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/userinfo/"
      FREESCOUT_OIDC_LOGOUT_URL: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/freescout/end-session/"
      FREESCOUT_OIDC_DISPLAY_NAME: "Authentik"
      PHP_CURL_CAINFO: "/usr/local/share/ca-certificates/mkcert-ca.crt"
{% endif %}
{% if install_mailpit | default(false) %}
      # ── SMTP relay → Mailpit (dev mail capture) ────────────────────────────
      # Mailpit lives on iiab_net only; reach it via host-gateway.
      # Switches MODE_MAIL away from the image's bundled postfix-relay default.
      MODE_MAIL: "SMTP"
      SMTP_HOST: "host.docker.internal"
      SMTP_PORT: "1025"
      SMTP_USERNAME: ""
      SMTP_PASSWORD: ""
      SMTP_ENCRYPTION: "null"
      MAIL_FROM_ADDRESS: "helpdesk@{{ tenant_domain | default('dev.local') }}"
{% endif %}
{% if (install_authentik | default(false)) or (install_mailpit | default(false)) %}
    extra_hosts:
{% if install_authentik | default(false) %}
      - "{{ authentik_domain | default('auth.dev.local') }}:host-gateway"
{% endif %}
{% if install_mailpit | default(false) %}
      - "host.docker.internal:host-gateway"
{% endif %}
{% endif %}
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ freescout_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ freescout_cpus | default(docker_cpus_light | default('0.5')) }}
