# {{ ansible_managed }}
# Wing nginx sidecar — minimal HTTP front for the FPM container.
# Traefik (edge, on shared_net) calls this on `wing-nginx:80`.
# Auth gating + security headers are applied at Traefik (authentik@file +
# security-headers@file middleware) — this config is intentionally lean.

worker_processes  1;
error_log  /var/log/nginx/error.log warn;
pid        /var/run/nginx.pid;

events {
    worker_connections  1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;
    sendfile      on;
    tcp_nopush    on;
    keepalive_timeout 65;

    log_format json escape=json '{'
        '"time":"$time_iso8601",'
        '"remote":"$remote_addr",'
        '"request":"$request",'
        '"status":$status,'
        '"bytes":$body_bytes_sent,'
        '"ref":"$http_referer",'
        '"ua":"$http_user_agent",'
        '"x_fwd":"$http_x_forwarded_for",'
        '"x_fwd_user":"$http_x_authentik_username"'
    '}';
    access_log /var/log/nginx/access.log json;

    # PHP-FPM upstream — Wing FPM container on the iiab_net Docker network.
    #
    # Docker-DNS resolver pinned to Docker Desktop's embedded DNS (127.0.0.11
    # inside the container's network namespace). nginx resolves the upstream
    # NAME at request time rather than caching the IP at startup, so a wing
    # container recreate (new IP) doesn't strand wing-nginx with a stale
    # `172.x.x.10` and 502s for hours. Surfaced 2026-05-04 after a full-blank
    # recreate left wing-nginx pointed at the previous wing IP. `valid=10s`
    # bounds the cache so re-resolution is cheap on busy paths.
    resolver 127.0.0.11 valid=10s ipv6=off;
    resolver_timeout 5s;

    # Variable-driven upstream forces re-resolution per request (per nginx
    # docs: when fastcgi_pass uses a literal hostname, it's resolved once at
    # config-load; using a variable forces dynamic lookup via the resolver).
    map $host $wing_upstream {
        default wing:9000;
    }

    server {
        listen      80 default_server;
        server_name _;

        root  {{ wing_app_dir | default(ansible_facts['env']['HOME'] + '/wing/app') }}/www;
        index index.php;

        # Healthcheck endpoint (used by docker healthcheck + Traefik service probe)
        location = /health {
            access_log off;
            return 200 "OK\n";
            add_header Content-Type text/plain;
        }

        # Hidden / sensitive files
        location ~ /\.            { deny all; }
        location ~* /(\.env|composer\.(json|lock)|\.neon|data/) { deny all; }

        # Static assets — long cache, no PHP
        location ~* ^/assets/.*\.(css|js|png|jpg|jpeg|gif|svg|woff2|ico)$ {
            expires 30d;
            add_header Cache-Control "public, immutable";
            access_log off;
        }

        # Front controller — PHP through FPM
        location / {
            try_files $uri $uri/ /index.php?$query_string;
        }

        location ~ \.php$ {
            # Variable upstream — see `resolver` block above; re-resolves per
            # request via Docker DNS so wing-container IP changes propagate
            # without a wing-nginx restart.
            fastcgi_pass  $wing_upstream;
            fastcgi_index index.php;
            include       /etc/nginx/fastcgi_params;
            fastcgi_param SCRIPT_FILENAME  $realpath_root$fastcgi_script_name;
            fastcgi_param DOCUMENT_ROOT    $realpath_root;
            # Forward Authentik headers from Traefik to PHP $_SERVER
            fastcgi_param HTTP_X_AUTHENTIK_USERNAME $http_x_authentik_username;
            fastcgi_param HTTP_X_AUTHENTIK_GROUPS   $http_x_authentik_groups;
            fastcgi_param HTTP_X_AUTHENTIK_EMAIL    $http_x_authentik_email;
            fastcgi_param HTTP_X_AUTHENTIK_UID      $http_x_authentik_uid;
            fastcgi_read_timeout 60s;
        }
    }
}
