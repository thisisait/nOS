# =============================================================================
# pazny.kiwix - compose override fragment
# Merged into `docker compose -p iiab up` in tasks/stacks/stack-up.yml via
# ansible.builtin.find over {{ stacks_dir }}/iiab/overrides/*.yml.
#
# Does not declare top-level networks: - iiab_net is defined in the base
# templates/stacks/iiab/docker-compose.yml.j2. Kiwix is purely local and does
# not attach to {{ stacks_shared_network }}.
# =============================================================================

services:
  kiwix:
    image: ghcr.io/kiwix/kiwix-serve:{{ kiwix_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ kiwix_port | default(8888) }}:8080"
{% else %}
      - "127.0.0.1:{{ kiwix_port | default(8888) }}:8080"
{% endif %}
    volumes:
      - {{ kiwix_data_dir }}:/data
    # Docker Compose does not shell-expand globs in command: — /data/*.zim
    # would be passed as a literal filename string, causing kiwix-serve to log
    # "Unable to add the ZIM file '/data/*.zim'" on every startup.
    # Override entrypoint so /bin/sh expands *.zim at container start.
    # $$ → $ after Docker Compose variable interpolation ($$ZIMS → $ZIMS in shell).
    entrypoint: ["/bin/sh", "-c"]
    command: |
      ZIMS=$$(ls /data/*.zim 2>/dev/null)
      if [ -n "$$ZIMS" ]; then
        exec /usr/local/bin/kiwix-serve --port=8080 $$ZIMS
      else
        echo "No ZIM files in /data — add .zim files and restart the kiwix container"
        exec sleep infinity
      fi
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ kiwix_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ kiwix_cpus | default(docker_cpus_light) }}
