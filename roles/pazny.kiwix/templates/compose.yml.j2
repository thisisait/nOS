# =============================================================================
# pazny.kiwix — compose override fragment
# Merged do `docker compose -p iiab up` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/iiab/overrides/*.yml.
#
# Nedeklaruje top-level networks: — iiab_net je definovana v base
# templates/stacks/iiab/docker-compose.yml.j2. Kiwix je cistě lokalni,
# nepripojuje se na {{ stacks_shared_network }}.
# =============================================================================

services:
  kiwix:
    image: ghcr.io/kiwix/kiwix-serve:{{ kiwix_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ kiwix_port | default(8888) }}:8080"
{% else %}
      - "127.0.0.1:{{ kiwix_port | default(8888) }}:8080"
{% endif %}
    volumes:
      - {{ kiwix_data_dir }}:/data
    command: /data/*.zim
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ kiwix_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ kiwix_cpus | default(docker_cpus_light) }}
