# =============================================================================
# pazny.superset — compose override fragment
# Merged into `docker compose -p data up` by tasks/stacks/stack-up.yml via
# ansible.builtin.find over {{ stacks_dir }}/data/overrides/*.yml.
#
# Does not declare top-level networks: — data_net and {{ stacks_shared_network }}
# are defined in base templates/stacks/data/docker-compose.yml.j2.
# =============================================================================

services:
  superset:
    # Build context is playbook_dir/files/superset — stays there so files/
    # keeps being the source-of-truth for overrideable Dockerfiles. The BASE
    # arg lets the role's superset_version default drive the upstream tag.
    build:
      context: {{ playbook_dir }}/files/superset
      dockerfile: Dockerfile
      args:
        BASE: "apache/superset:{{ superset_version | default('6.0.0-dev') }}"
    image: nos/superset:{{ superset_version | default('6.0.0-dev') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ superset_port | default(8089) }}:8088"
{% else %}
      - "127.0.0.1:{{ superset_port | default(8089) }}:8088"
{% endif %}
    volumes:
      - {{ superset_data_dir | default(ansible_facts['env']['HOME'] + '/superset') }}:/app/superset_home
      - {{ stacks_dir }}/data/overrides/superset_config.py:/app/pythonpath/superset_config.py:ro
    environment:
      SUPERSET_CONFIG_PATH: /app/pythonpath/superset_config.py
      PYTHONPATH: /app/pythonpath
      SUPERSET_SECRET_KEY: "{{ superset_secret_key | default(global_password_prefix + '_pw_superset_secret') }}"
      DATABASE_HOST: postgresql
      DATABASE_PORT: "5432"
      DATABASE_DB: "{{ superset_db_name | default('superset') }}"
      DATABASE_USER: "{{ superset_db_user | default('superset') }}"
      DATABASE_PASSWORD: "{{ superset_db_password | default(global_password_prefix + '_pw_superset') }}"
      REDIS_HOST: redis
      REDIS_PORT: "6379"
      REDIS_PASSWORD: "{{ redis_password | default(global_password_prefix + '_pw_redis') }}"
    extra_hosts:
      - "{{ authentik_domain | default('auth.dev.local') }}:host-gateway"
    networks:
      - data_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ superset_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
