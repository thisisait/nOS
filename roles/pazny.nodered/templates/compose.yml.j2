# =============================================================================
# pazny.nodered - compose override fragment
# Merged into `docker compose -p iiab up` in tasks/stacks/stack-up.yml via
# ansible.builtin.find over {{ stacks_dir }}/iiab/overrides/*.yml.
#
# Does not declare top-level networks: - iiab_net and {{ stacks_shared_network }}
# are defined in the base templates/stacks/iiab/docker-compose.yml.j2.
#
# The nodered/node-red image is multi-arch (amd64 + arm64) - runs natively on M1.
# The container runs as UID 1000 (defaults/main.yml: nodered_uid).
# =============================================================================

services:
  nodered:
    image: nodered/node-red:{{ nodered_version | default('4.0.9') }}
    restart: unless-stopped
    user: "{{ nodered_uid | default(1000) }}:{{ nodered_gid | default(1000) }}"
    ports:
{% if services_lan_access | default(false) %}
      - "{{ nodered_port | default(1880) }}:1880"
{% else %}
      - "127.0.0.1:{{ nodered_port | default(1880) }}:1880"
{% endif %}
    volumes:
      - {{ nodered_data_dir }}:/data
{% if install_authentik | default(false) and (tenant_domain_is_local | default(true) | bool) %}
      # mkcert CA conditional — local TLDs only (regression class sweep 2026-05-03).
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/usr/local/share/ca-certificates/mkcert-ca.crt:ro
{% endif %}
    environment:
      TZ: "{{ nodered_timezone | default('Europe/Prague') }}"
      FLOWS: "{{ nodered_flows_file | default('flows.json') }}"
      NODE_RED_ENABLE_SAFE_MODE: "{{ nodered_enable_safe_mode | default('false') }}"
      NODE_RED_ENABLE_PROJECTS: "{{ nodered_enable_projects | default('true') }}"
{% if install_authentik | default(false) and (tenant_domain_is_local | default(true) | bool) %}
      NODE_EXTRA_CA_CERTS: "/usr/local/share/ca-certificates/mkcert-ca.crt"
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "wget --spider -q http://127.0.0.1:1880/ 2>&1 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s
{% if install_authentik | default(false) %}
    extra_hosts:
      - "{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}:host-gateway"
{% endif %}
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ nodered_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ nodered_cpus | default(docker_cpus_standard | default('1.0')) }}
