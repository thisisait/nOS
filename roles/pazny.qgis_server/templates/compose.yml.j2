# =============================================================================
# pazny.qgis_server - compose override fragment
# Merged into `docker compose -p engineering up` in tasks/stacks/stack-up.yml
# via ansible.builtin.find over {{ stacks_dir }}/engineering/overrides/*.yml.
#
# Does not declare top-level networks: - engineering_net is defined in the base
# templates/stacks/engineering/docker-compose.yml.j2.
#
# QGIS Server is amd64-only - on ARM64 Mac it runs via Rosetta emulation.
# =============================================================================

services:
  qgis-server:
    image: kartoza/qgis-server:{{ qgis_version | default('latest') }}
    platform: linux/amd64    # amd64 only - Docker Desktop emulates via Rosetta
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ qgis_port | default(8071) }}:80"
    volumes:
      - {{ qgis_data_dir | default(ansible_facts['env']['HOME'] + '/qgis') }}/projects:/io/data
    environment:
      QGIS_SERVER_LOG_LEVEL: "2"
      QGIS_SERVER_MAX_THREADS: "4"
      QGIS_SERVER_PARALLEL_RENDERING: "true"
    networks:
      - engineering_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ qgis_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ docker_cpus_light | default('0.5') }}
