# =============================================================================
# pazny.code_server — compose override fragment
# Merged do `docker compose -p devops up` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/devops/overrides/*.yml.
#
# Nedeklaruje top-level networks: — devops_net a {{ stacks_shared_network }}
# jsou definovane v base templates/stacks/devops/docker-compose.yml.j2.
#
# SSO: proxy auth — Authentik forward_auth v nginx.conf. PASSWORD /
# HASHED_PASSWORD jsou prazdne, takze code-server nevyzaduje built-in login.
# =============================================================================

services:
  code-server:
    image: lscr.io/linuxserver/code-server:{{ code_server_version | default('4.115.0-ls332') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ code_server_port | default(3009) }}:8443"
{% else %}
      - "127.0.0.1:{{ code_server_port | default(3009) }}:8443"
{% endif %}
    volumes:
      - {{ code_server_data_dir }}:/config
      - {{ code_server_workspace_dir }}:/config/workspace
{% if install_authentik | default(false) %}
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/usr/local/share/ca-certificates/mkcert-ca.crt:ro
{% endif %}
    environment:
      PUID: "{{ code_server_puid | default(1000) }}"
      PGID: "{{ code_server_pgid | default(1000) }}"
      TZ: "{{ code_server_tz | default('Europe/Prague') }}"
      # PASSWORD / HASHED_PASSWORD nechane prazdne — pristup gatuje Authentik
      # forward_auth v nginx vhostu. Built-in code-server login je tak vypnuty.
      PASSWORD: ""
      HASHED_PASSWORD: ""
      SUDO_PASSWORD: ""
      PROXY_DOMAIN: "{{ code_server_domain | default('code' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
      DEFAULT_WORKSPACE: "{{ code_server_default_workspace | default('/config/workspace') }}"
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:8443/healthz || curl -sf http://localhost:8443/ || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 60s
{% if install_authentik | default(false) %}
    extra_hosts:
      - "{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}:host-gateway"
{% endif %}
    networks:
      - devops_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ code_server_mem_limit | default(docker_mem_limit_critical) }}
    cpus: {{ code_server_cpus | default(docker_cpus_standard | default('1.0')) }}
