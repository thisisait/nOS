# =============================================================================
# pazny.nginx_container — compose override fragment
# Merged into `docker compose up infra` in tasks/stacks/core-up.yml via
# ansible.builtin.find over {{ stacks_dir }}/infra/overrides/*.yml.
#
# Reads vhost configuration from {{ nginx_container_root }} (host bind
# mount, read-only). Configuration is rendered there by tasks/nginx.yml
# AS IF it were the homebrew_prefix path on the host, just relocated.
#
# `extra_hosts: nos-host:host-gateway` is the cross-platform escape hatch
# that lets vhost templates' `proxy_pass http://{{ nginx_backend_host }}:PORT`
# reach the host's loopback regardless of platform — Docker Desktop on
# macOS resolves host-gateway to vEthernet, Linux Docker resolves to the
# docker0 bridge IP. Same alias, same vhost text, two platforms.
# =============================================================================

services:
  nginx:
    image: {{ nginx_container_image }}
    container_name: nginx
    restart: unless-stopped
    ports:
      - "{{ nginx_container_http_port }}:80"
      - "{{ nginx_container_https_port }}:443"
    volumes:
      # Config tree — main config + sites-available + sites-enabled +
      # snippet includes. Read-only: tasks/nginx.yml writes to the host
      # path, container only reads.
      - {{ nginx_container_etc }}:/etc/nginx:ro
      # Logs (access + error). Writable so nginx can append. Inspect via
      # `tail -f {{ nginx_container_logs }}/access.log` from the host.
      - {{ nginx_container_logs }}:/var/log/nginx:rw
      # Cache directory (proxy cache, fastcgi cache). Writable, ephemeral.
      - {{ nginx_container_cache }}:/var/cache/nginx:rw
{% if install_wing | default(true) %}
      # Wing source dir — same path inside container so SCRIPT_FILENAME
      # values nginx hands to FPM resolve correctly when both nginx and
      # FPM are containerized. Read-only — only static asset serving uses
      # this side; FPM bind-mounts the same path with rw.
      - {{ wing_app_dir | default(ansible_facts['env']['HOME'] + '/wing/app') }}:{{ wing_app_dir | default(ansible_facts['env']['HOME'] + '/wing/app') }}:ro
{% endif %}
    networks:
      - infra_net
{% for stack in ['iiab', 'devops', 'b2b', 'voip', 'engineering', 'data'] %}
      - {{ stack }}_net
{% endfor %}
    extra_hosts:
      # Cross-platform host loopback alias — see nginx_backend_host in
      # defaults/main.yml. Vhost templates use `proxy_pass http://nos-host:<port>`.
      - "nos-host:host-gateway"
      - "host.docker.internal:host-gateway"
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ nginx_container_mem_limit }}
    cpus: {{ docker_cpus_light | default('0.5') }}
    healthcheck:
      # nginx -t validates config; if it parses + listens, container is up.
      test: ["CMD", "nginx", "-t"]
      interval: 60s
      timeout: 5s
      start_period: 10s
      retries: 3
