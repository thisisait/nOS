# =============================================================================
# pazny.postgresql — compose override fragment
# Merged do `docker compose up` v tasks/stacks/core-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/infra/overrides/*.yml.
#
# Nedeklaruje top-level networks: — infra_net a {{ stacks_shared_network }}
# jsou definovane v base templates/stacks/infra/docker-compose.yml.j2.
# Docker compose merge semantics umoznuje referencovat vnejsi networky
# dokud je kterykoli z merge-ovanych souboru definuje.
# =============================================================================

services:
  postgresql:
    image: postgres:{{ postgresql_version | default('16-alpine') }}
    hostname: postgresql
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ postgresql_port | default(5432) }}:5432"
    volumes:
      - {{ postgresql_data_dir | default(ansible_facts['env']['HOME'] + '/postgresql/data') }}:/var/lib/postgresql/data
    command: ["-c", "max_connections={{ postgresql_max_connections | default(300) }}"]
    environment:
      POSTGRES_PASSWORD: "{{ postgresql_root_password | default(global_password_prefix + '_pw_postgresql') }}"
      POSTGRES_USER: "{{ postgresql_root_user | default('postgres') }}"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgresql_root_user | default('postgres') }}"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 15s
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ postgresql_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
