# =============================================================================
# pazny.postgresql — compose override fragment
# Merged into `docker compose up` by tasks/stacks/core-up.yml via
# ansible.builtin.find across {{ stacks_dir }}/infra/overrides/*.yml.
#
# Does not declare top-level networks: — infra_net and {{ stacks_shared_network }}
# are defined in base templates/stacks/infra/docker-compose.yml.j2.
# Docker compose merge semantics allow referencing external networks as long
# as any of the merged files defines them.
# =============================================================================

services:
  postgresql:
    image: postgres:{{ postgresql_version | default('16-alpine') }}
    hostname: postgresql
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ postgresql_port | default(5432) }}:5432"
    volumes:
      - {{ postgresql_data_dir | default(ansible_facts['env']['HOME'] + '/postgresql/data') }}:/var/lib/postgresql/data
    command:
      - "-c"
      - "max_connections={{ postgresql_max_connections | default(600) }}"
      - "-c"
      # Auto-close truly idle client sessions. Authentik 2025.x has a pool
      # leak that grows to ~400 idle connections even with CONN_MAX_AGE=0;
      # letting PostgreSQL reap them server-side is the reliable fix.
      - "idle_session_timeout={{ postgresql_idle_session_timeout_ms | default(300000) }}"
      - "-c"
      # Safety net for rogue clients that open a transaction and wander off.
      - "idle_in_transaction_session_timeout={{ postgresql_idle_in_transaction_timeout_ms | default(60000) }}"
    environment:
      POSTGRES_PASSWORD: "{{ postgresql_root_password | default(global_password_prefix + '_pw_postgresql') }}"
      POSTGRES_USER: "{{ postgresql_root_user | default('postgres') }}"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgresql_root_user | default('postgres') }}"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 15s
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ postgresql_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
