# =============================================================================
# pazny.gitlab — compose override fragment
# Merged into `docker compose -p devops up` by tasks/stacks/stack-up.yml via
# ansible.builtin.find across {{ stacks_dir }}/devops/overrides/*.yml.
# =============================================================================

services:
  gitlab:
    image: gitlab/gitlab-ce:{{ gitlab_version | default('latest') }}
    restart: unless-stopped
    hostname: "{{ gitlab_domain | default('gitlab' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
    shm_size: 256m
    ports:
      - "127.0.0.1:{{ gitlab_http_port | default(8929) }}:80"
      - "127.0.0.1:{{ gitlab_ssh_port | default(2224) }}:22"
    volumes:
      - {{ gitlab_config_dir }}:/etc/gitlab
      - {{ ansible_facts['env']['HOME'] }}/gitlab-logs:/var/log/gitlab
      - {{ gitlab_data_dir }}:/var/opt/gitlab
{# mkcert CA volume + authentik extra_host moved to gitlab-base plugin (D2). #}
    environment:
      GITLAB_OMNIBUS_CONFIG: |
        external_url 'https://{{ gitlab_domain | default('gitlab' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}'
        gitlab_rails['gitlab_shell_ssh_port'] = {{ gitlab_ssh_port | default(2224) }}
        nginx['listen_port'] = 80
        nginx['listen_https'] = false
        puma['worker_processes'] = 2
        sidekiq['concurrency'] = 10
        postgresql['shared_buffers'] = '256MB'
        prometheus['enable'] = false
        alertmanager['enable'] = false
        node_exporter['enable'] = false
        redis_exporter['enable'] = false
        postgres_exporter['enable'] = false
        gitlab_exporter['enable'] = false
        gitlab_rails['gitlab_signup_enabled'] = false
        gitlab_rails['time_zone'] = 'Europe/Prague'
{% if install_authentik | default(false) %}
        gitlab_rails['omniauth_enabled'] = true
        gitlab_rails['omniauth_allow_single_sign_on'] = ['openid_connect']
        gitlab_rails['omniauth_block_auto_created_users'] = false
        gitlab_rails['omniauth_providers'] = [{ name: 'openid_connect', label: 'Authentik', args: { name: 'openid_connect', scope: ['openid', 'profile', 'email'], response_type: 'code', issuer: 'https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/application/o/gitlab/', client_auth_method: 'query', discovery: true, uid_field: 'preferred_username', client_options: { identifier: 'nos-gitlab', secret: '{{ global_password_prefix }}_pw_oidc_gitlab', redirect_uri: 'https://{{ gitlab_domain | default('gitlab' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/users/auth/openid_connect/callback' } } }]
{% endif %}
{# authentik extra_host moved to gitlab-base plugin compose-extension (D2). #}
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:80/-/readiness || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 15
      start_period: 300s
    networks:
      - devops_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "50m"
        max-file: "5"
    mem_limit: {{ gitlab_mem_limit | default(docker_mem_limit_heavy) }}
    cpus: {{ docker_cpus_heavy | default('2.0') }}
