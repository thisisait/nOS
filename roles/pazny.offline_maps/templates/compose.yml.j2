# =============================================================================
# pazny.offline_maps — compose override fragment
# Merged do `docker compose -p iiab up` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/iiab/overrides/*.yml.
#
# Nedeklaruje top-level networks: — iiab_net je definovana v base
# templates/stacks/iiab/docker-compose.yml.j2. Tileserver je lokalni,
# nepripojuje se na {{ stacks_shared_network }}.
#
# Compose service name zustava `tileserver`; role name `offline_maps`
# odrazi celou subsystemu (compose service + MBTiles + config render).
# =============================================================================

services:
  tileserver:
    image: maptiler/tileserver-gl:{{ maps_tileserver_version | default('latest') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ maps_port | default(8070) }}:8080"
    volumes:
      - {{ maps_data_dir }}:/data
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ tileserver_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ tileserver_cpus | default(docker_cpus_light) }}
