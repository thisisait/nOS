# =============================================================================
# pazny.outline — compose override fragment
# Merged do `docker compose up` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/b2b/overrides/*.yml.
# =============================================================================

services:
  outline:
    image: outlinewiki/outline:{{ outline_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ outline_port | default(3005) }}:3000"
{% else %}
      - "127.0.0.1:{{ outline_port | default(3005) }}:3000"
{% endif %}
    volumes:
      - {{ outline_data_dir | default(ansible_facts['env']['HOME'] + '/outline/data') }}:/var/lib/outline/data
    environment:
      NODE_ENV: production
      SECRET_KEY: "{{ outline_secret_key | default(global_password_prefix + '_pw_outline_secret') }}"
      UTILS_SECRET: "{{ outline_utils_secret | default(global_password_prefix + '_pw_outline_utils') }}"
      DATABASE_URL: "postgres://{{ outline_db_user | default('outline') }}:{{ (outline_db_password | default(global_password_prefix + '_pw_outline')) | urlencode }}@postgresql:5432/{{ outline_db_name | default('outline') }}"
      PGSSLMODE: "disable"
      REDIS_URL: "redis://:{{ (redis_password | default(global_password_prefix + '_pw_redis')) | urlencode }}@redis:6379"
      URL: "https://{{ outline_domain | default('wiki' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
      PORT: "3000"
      FORCE_HTTPS: "false"
      FILE_STORAGE: local
      FILE_STORAGE_LOCAL_ROOT_DIR: /var/lib/outline/data
{# OIDC env + mkcert CA volume + authentik extra_host moved to outline-base
   plugin compose-extension (D2 2026-05-05). #}
{% if install_mailpit | default(false) %}
      # ── SMTP relay → Mailpit (dev mail capture) ────────────────────────────
      # Mailpit lives on iiab_net only; reach it via host-gateway.
      SMTP_HOST: "host.docker.internal"
      SMTP_PORT: "1025"
      SMTP_FROM_EMAIL: "outline@{{ tenant_domain | default('dev.local') }}"
      SMTP_REPLY_EMAIL: "outline@{{ tenant_domain | default('dev.local') }}"
      SMTP_TLS_CIPHERS: ""
      SMTP_SECURE: "false"
{% endif %}
{% if install_mailpit | default(false) %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
{# Authentik extra_host moved to outline-base plugin compose-extension (D2). #}
    healthcheck:
      test: ["CMD-SHELL", "wget --spider -q http://localhost:3000/_health 2>&1 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      # 180s (was 60s, 2026-05-08): on cold blank Outline goes through
      # Node 22 boot + Postgres schema migration + Redis collab init +
      # OIDC plugin registration before /_health responds 200. 60s wasn't
      # enough — `docker compose up --wait` saw an early failed probe
      # (FailingStreak=1 then healthy) and returned rc=1, tripping
      # tasks/stacks/stack-up.yml's fail-fast assert with a transient
      # "container b2b-outline-1 is unhealthy" message. By the time the
      # operator inspected, the container was healthy. 180s tolerates
      # the documented 90-120s cold cluster startup with margin.
      start_period: 180s
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ outline_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ outline_cpus | default(docker_cpus_standard | default('1.0')) }}
