# =============================================================================
# pazny.bookstack — compose override fragment
# Merged into `docker compose up b2b` by tasks/stacks/stack-up.yml via
# ansible.builtin.find across {{ stacks_dir }}/b2b/overrides/*.yml.
#
# Does not declare top-level networks: — b2b_net and {{ stacks_shared_network }}
# are defined in base templates/stacks/b2b/docker-compose.yml.j2.
#
# BookStack requires: MariaDB (from the infra stack via shared_net) +
# optionally Redis for cache/session/queue.
# OIDC client_id/secret is read from the central authentik_oidc_apps list
# in default.config.yml via derived authentik_oidc_bookstack_* variables.
# =============================================================================

services:
  bookstack:
    image: lscr.io/linuxserver/bookstack:{{ bookstack_version | default('v26.03.3-ls256') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ bookstack_port | default(3013) }}:80"
{% else %}
      - "127.0.0.1:{{ bookstack_port | default(3013) }}:80"
{% endif %}
    volumes:
      - {{ bookstack_data_dir }}:/config
{% if install_authentik | default(false) %}
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/usr/local/share/ca-certificates/mkcert-ca.crt:ro
{% endif %}
    environment:
      PUID: "{{ bookstack_puid | default(1000) }}"
      PGID: "{{ bookstack_pgid | default(1000) }}"
      TZ: "{{ bookstack_tz | default('Europe/Prague') }}"
      APP_URL: "https://{{ bookstack_domain | default('bookstack.dev.local') }}"
      APP_KEY: "{{ bookstack_app_key }}"
      APP_DEBUG: "false"
      DB_HOST: "{% if install_mariadb | default(false) %}mariadb{% else %}{{ bookstack_db_host | default('127.0.0.1') }}{% endif %}"
      DB_PORT: "3306"
      DB_DATABASE: "{{ bookstack_db_name | default('bookstack') }}"
      DB_USERNAME: "{{ bookstack_db_user | default('bookstack') }}"
      DB_PASSWORD: "{{ bookstack_db_password }}"
{% if redis_docker | default(false) %}
      CACHE_DRIVER: "redis"
      SESSION_DRIVER: "redis"
      QUEUE_CONNECTION: "redis"
      REDIS_SERVERS: "redis:6379:0:{{ redis_password | default(global_password_prefix + '_pw_redis') }}"
{% endif %}
{% if install_authentik | default(false) %}
      # ── Authentik SSO (OIDC) ───────────────────────────────────────────────
      AUTH_METHOD: "oidc"
      OIDC_NAME: "Authentik"
      OIDC_DISPLAY_NAME_CLAIMS: "name"
      OIDC_CLIENT_ID: "{{ authentik_oidc_bookstack_client_id }}"
      OIDC_CLIENT_SECRET: "{{ authentik_oidc_bookstack_client_secret }}"
      OIDC_ISSUER: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/bookstack/"
      OIDC_ISSUER_DISCOVER: "true"
      OIDC_USER_TO_GROUPS: "true"
      OIDC_ADDITIONAL_SCOPES: "groups"
{% endif %}
{% if install_mailpit | default(false) %}
      # ── SMTP relay → Mailpit (dev mail capture) ────────────────────────────
      # Mailpit lives on iiab_net only; reach it via host-gateway.
      MAIL_DRIVER: "smtp"
      MAIL_HOST: "host.docker.internal"
      MAIL_PORT: "1025"
      MAIL_USERNAME: ""
      MAIL_PASSWORD: ""
      MAIL_FROM: "bookstack@{{ tenant_domain | default('dev.local') }}"
      MAIL_FROM_NAME: "BookStack"
      MAIL_ENCRYPTION: ""
{% endif %}
{% if (install_authentik | default(false)) or (install_mailpit | default(false)) %}
    extra_hosts:
{% if install_authentik | default(false) %}
      - "{{ authentik_domain | default('auth.dev.local') }}:host-gateway"
{% endif %}
{% if install_mailpit | default(false) %}
      - "host.docker.internal:host-gateway"
{% endif %}
{% endif %}
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    # The authoritative config is /config/www/.env (rendered by the role into
    # {{ bookstack_data_dir }}/www/.env). /login is the cheapest HTTP endpoint
    # that exercises the Laravel boot path — if it answers 200 the app, DB,
    # and .env are all wired correctly.
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS -o /dev/null -w '%{http_code}' http://127.0.0.1/login | grep -q '^200$' || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ bookstack_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ bookstack_cpus | default(docker_cpus_standard | default('1.0')) }}
