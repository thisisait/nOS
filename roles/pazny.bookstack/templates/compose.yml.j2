# =============================================================================
# pazny.bookstack — compose override fragment
# Merged do `docker compose up b2b` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/b2b/overrides/*.yml.
#
# Nedeklaruje top-level networks: — b2b_net a {{ stacks_shared_network }}
# jsou definovane v base templates/stacks/b2b/docker-compose.yml.j2.
#
# BookStack vyzaduje: MariaDB (z infra stacku pres shared_net) + volitelne
# Redis pro cache/session/queue.
# OIDC client_id/secret se cte z centralniho authentik_oidc_apps listu
# v default.config.yml pres derivovane authentik_oidc_bookstack_* promenne.
# =============================================================================

services:
  bookstack:
    image: lscr.io/linuxserver/bookstack:{{ bookstack_version | default('v26.03.3-ls256') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ bookstack_port | default(3013) }}:80"
{% else %}
      - "127.0.0.1:{{ bookstack_port | default(3013) }}:80"
{% endif %}
    volumes:
      - {{ bookstack_data_dir }}:/config
{% if install_authentik | default(false) %}
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/usr/local/share/ca-certificates/mkcert-ca.crt:ro
{% endif %}
    environment:
      PUID: "{{ bookstack_puid | default(1000) }}"
      PGID: "{{ bookstack_pgid | default(1000) }}"
      TZ: "{{ bookstack_tz | default('Europe/Prague') }}"
      APP_URL: "https://{{ bookstack_domain | default('bookstack.dev.local') }}"
      APP_KEY: "{{ bookstack_app_key }}"
      APP_DEBUG: "false"
      DB_HOST: "{% if install_mariadb | default(false) %}mariadb{% else %}{{ bookstack_db_host | default('127.0.0.1') }}{% endif %}"
      DB_PORT: "3306"
      DB_DATABASE: "{{ bookstack_db_name | default('bookstack') }}"
      DB_USERNAME: "{{ bookstack_db_user | default('bookstack') }}"
      DB_PASSWORD: "{{ bookstack_db_password }}"
{% if redis_docker | default(false) %}
      CACHE_DRIVER: "redis"
      SESSION_DRIVER: "redis"
      QUEUE_CONNECTION: "redis"
      REDIS_SERVERS: "redis:6379:0:{{ redis_password | default(global_password_prefix + '_pw_redis') }}"
{% endif %}
{% if install_authentik | default(false) %}
      # ── Authentik SSO (OIDC) ───────────────────────────────────────────────
      AUTH_METHOD: "oidc"
      OIDC_NAME: "Authentik"
      OIDC_DISPLAY_NAME_CLAIMS: "name"
      OIDC_CLIENT_ID: "{{ authentik_oidc_bookstack_client_id }}"
      OIDC_CLIENT_SECRET: "{{ authentik_oidc_bookstack_client_secret }}"
      OIDC_ISSUER: "https://{{ authentik_domain | default('auth.dev.local') }}/application/o/bookstack/"
      OIDC_ISSUER_DISCOVER: "true"
      OIDC_USER_TO_GROUPS: "true"
      OIDC_ADDITIONAL_SCOPES: "groups"
{% endif %}
{% if install_authentik | default(false) %}
    extra_hosts:
      - "{{ authentik_domain | default('auth.dev.local') }}:host-gateway"
{% endif %}
    networks:
      - b2b_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ bookstack_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ bookstack_cpus | default(docker_cpus_standard | default('1.0')) }}
