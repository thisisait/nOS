# =============================================================================
# Laravel .env for BookStack — rendered by pazny.bookstack/tasks/main.yml.
#
# BookStack's linuxserver/bookstack image runs PHP-FPM, which reads /app/www/.env
# (symlinked to /config/www/.env inside the container). Docker `environment:`
# values are NOT merged into .env on restart — the LSIO init seeds .env from
# .env.example ONCE on first boot and never regenerates it. So we render the
# file ourselves and bind-mount it via {{ bookstack_data_dir }} -> /config.
#
# Editing this template and re-running the playbook will overwrite any manual
# changes under /config/www/.env on disk.
# =============================================================================

APP_KEY={{ bookstack_app_key }}
APP_URL=https://{{ bookstack_domain | default('bookstack.dev.local') }}
APP_DEBUG=false

# Database (MariaDB, shared from the infra stack via b2b_net)
DB_HOST={% if install_mariadb | default(false) %}mariadb{% else %}{{ bookstack_db_host | default('127.0.0.1') }}{% endif %}

DB_PORT=3306
DB_DATABASE={{ bookstack_db_name | default('bookstack') }}
DB_USERNAME={{ bookstack_db_user | default('bookstack') }}
DB_PASSWORD={{ bookstack_db_password }}

{% if redis_docker | default(false) %}
# Redis (cache / session / queue)
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_SERVERS=redis:6379:0:{{ redis_password | default(global_password_prefix + '_pw_redis') }}
{% endif %}

{% if install_authentik | default(false) %}
# ── Authentik SSO (native OIDC) ──────────────────────────────────────────────
AUTH_METHOD=oidc
OIDC_NAME=Authentik
OIDC_DISPLAY_NAME_CLAIMS=name
OIDC_CLIENT_ID={{ authentik_oidc_bookstack_client_id }}
OIDC_CLIENT_SECRET={{ authentik_oidc_bookstack_client_secret }}
OIDC_ISSUER=https://{{ authentik_domain | default('auth.dev.local') }}/application/o/bookstack/
OIDC_ISSUER_DISCOVER=true
OIDC_USER_TO_GROUPS=true
OIDC_ADDITIONAL_SCOPES=groups
{% endif %}
