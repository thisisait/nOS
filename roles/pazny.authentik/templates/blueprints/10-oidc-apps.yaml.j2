# yaml-language-server: $schema=https://goauthentik.io/blueprints/schema.json
# ── devBoxNOS OAuth2 / Proxy providers + aplikace ────────────────────────────
# Spravovano Ansible playbookem. Zdroj: authentik_oidc_apps list v
# default.config.yml. Pri kazdem blueprint reconcile se hodnoty
# (zejmena client_secret, redirect_uris, external_host) prepisou do
# existujici DB → prefix rotation se propise atomicky do obou stran
# (Authentik DB + service compose env var, oba cteny z teze Jinja promenne).

version: 1
metadata:
  name: devboxnos-oidc-apps
  labels:
    managed-by: devboxnos
    blueprint-version: "1"

entries:
{% for app in authentik_oidc_apps | default([]) %}
{% if app.enabled | default(false) | bool %}
{% set app_type = app.type | default('oauth2') %}
{% if app_type == 'oauth2' %}
  # ── {{ app.name }} (OAuth2 / OIDC) ──
  - model: authentik_providers_oauth2.oauth2provider
    state: present
    identifiers:
      name: "{{ app.name }}"
    attrs:
      client_type: "confidential"
      client_id: "{{ app.client_id }}"
      client_secret: "{{ app.client_secret }}"
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      access_code_validity: "minutes=10"
      access_token_validity: "minutes=10"
      refresh_token_validity: "days=30"
      sub_mode: "hashed_user_id"
      include_claims_in_id_token: true
      issuer_mode: "per_provider"
      redirect_uris:
        - matching_mode: "strict"
          url: "{{ app.redirect_uris }}"
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, authentik Self-signed Certificate]]

  - model: authentik_core.application
    state: present
    identifiers:
      slug: "{{ app.slug }}"
    attrs:
      name: "{{ app.name }}"
      meta_launch_url: "{{ app.launch_url }}"
      provider: !Find [authentik_providers_oauth2.oauth2provider, [name, "{{ app.name }}"]]
      policy_engine_mode: "any"
      open_in_new_tab: true
{% else %}
  # ── {{ app.name }} (Proxy forward auth) ──
  - model: authentik_providers_proxy.proxyprovider
    state: present
    identifiers:
      name: "{{ app.name }}"
    attrs:
      external_host: "{{ app.external_host }}"
      mode: "forward_single"
      internal_host_ssl_validation: false
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]

  - model: authentik_core.application
    state: present
    identifiers:
      slug: "{{ app.slug }}"
    attrs:
      name: "{{ app.name }}"
      meta_launch_url: "{{ app.launch_url }}"
      provider: !Find [authentik_providers_proxy.proxyprovider, [name, "{{ app.name }}"]]
      policy_engine_mode: "any"
      open_in_new_tab: true
{% endif %}
{% endif %}
{% endfor %}

  # ── Embedded outpost: bind vsechny proxy providery ──────────────────────
  - model: authentik_outposts.outpost
    state: present
    identifiers:
      managed: "goauthentik.io/outposts/embedded"
    attrs:
      name: "authentik Embedded Outpost"
      type: "proxy"
      providers:
{% for app in authentik_oidc_apps | default([]) %}
{% if app.enabled | default(false) | bool and (app.type | default('oauth2')) == 'proxy' %}
        - !Find [authentik_providers_proxy.proxyprovider, [name, "{{ app.name }}"]]
{% endif %}
{% endfor %}
      config:
        authentik_host: "https://{{ authentik_domain | default('auth.dev.local') }}"
        authentik_host_browser: "https://{{ authentik_domain | default('auth.dev.local') }}"
        authentik_host_insecure: false
        log_level: "info"
        object_naming_template: "ak-outpost-%(name)s"
        docker_labels: null
        docker_network: null
        container_image: null
        kubernetes_replicas: 1
        kubernetes_namespace: "authentik"
