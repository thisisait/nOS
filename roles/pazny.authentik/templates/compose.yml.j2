# =============================================================================
# pazny.authentik — compose override fragment (server + worker)
# Merged do `docker compose -p infra up` v tasks/stacks/core-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/infra/overrides/*.yml.
#
# Nedeklaruje top-level networks: — infra_net a {{ stacks_shared_network }}
# jsou definovane v base templates/stacks/infra/docker-compose.yml.j2.
# Docker compose merge semantics umoznuje referencovat vnejsi networky
# dokud je kterykoli z merge-ovanych souboru definuje.
#
# Blueprint bind mount: {{ stacks_dir }}/infra/authentik/blueprints → /blueprints/custom
# je sdileny mezi server a worker. Render fragmentu zajistuje
# roles/pazny.authentik/tasks/blueprints.yml (volana z tasks/main.yml).
# =============================================================================

services:
  # ── Authentik – SSO / Identity Provider ──────────────────────────────────────
  authentik-server:
    image: ghcr.io/goauthentik/server:{{ authentik_version | default('2025.2') }}
    command: server
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ authentik_port | default(9000) }}:9000"
{% else %}
      - "127.0.0.1:{{ authentik_port | default(9000) }}:9000"
{% endif %}
    volumes:
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/media:/media
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/templates:/templates
      - {{ stacks_dir }}/infra/authentik/blueprints:/blueprints/custom:ro
    environment:
      AUTHENTIK_SECRET_KEY: "{{ authentik_secret_key }}"
      AUTHENTIK_REDIS__HOST: redis
      AUTHENTIK_REDIS__PASSWORD: "{{ redis_password | default(global_password_prefix + '_pw_redis') }}"
      AUTHENTIK_POSTGRESQL__HOST: postgresql
      AUTHENTIK_POSTGRESQL__USER: "{{ authentik_db_user | default('authentik') }}"
      AUTHENTIK_POSTGRESQL__NAME: "{{ authentik_db_name | default('authentik') }}"
      AUTHENTIK_POSTGRESQL__PASSWORD: "{{ authentik_db_password }}"
      # Zavirat DB spojeni po kazdem requestu misto persistentniho poolu —
      # bez teto konfigurace drzi Authentik 2025.2 na sdilenem Postgresu
      # ~290 idle spojeni, coz vycerpa max_connections=300 a zabije ostatni
      # klienty (Outline, Hedgedoc, Firefly) chybou "remaining connection
      # slots are reserved for SUPERUSER". 0 = close after each request.
      AUTHENTIK_POSTGRESQL__CONN_MAX_AGE: "{{ authentik_pg_conn_max_age | default(0) }}"
      AUTHENTIK_POSTGRESQL__CONN_HEALTH_CHECKS: "true"
      AUTHENTIK_WEB__WORKERS: "{{ authentik_web_workers | default(2) }}"
      AUTHENTIK_WEB__THREADS: "{{ authentik_web_threads | default(4) }}"
      AUTHENTIK_BOOTSTRAP_PASSWORD: "{{ authentik_bootstrap_password }}"
      AUTHENTIK_BOOTSTRAP_EMAIL: "{{ authentik_bootstrap_email | default(default_admin_email) }}"
      AUTHENTIK_ERROR_REPORTING__ENABLED: "false"
      AUTHENTIK_DISABLE_STARTUP_ANALYTICS: "true"
      AUTHENTIK_COOKIE_DOMAIN: "{{ _host_alias_seg | default('') }}.{{ tenant_domain | default('dev.local') }}"
      AUTHENTIK_HOST: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
      AUTHENTIK_HOST_BROWSER: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
{% if install_mailpit | default(false) %}
      # ── SMTP relay → Mailpit (dev mail capture) ────────────────────────────
      # Mailpit lives on iiab_net only; reach it via the host-gateway
      # (Mailpit is bound to 127.0.0.1:1025 on the host).
      AUTHENTIK_EMAIL__HOST: "host.docker.internal"
      AUTHENTIK_EMAIL__PORT: "1025"
      AUTHENTIK_EMAIL__USERNAME: ""
      AUTHENTIK_EMAIL__PASSWORD: ""
      AUTHENTIK_EMAIL__USE_TLS: "False"
      AUTHENTIK_EMAIL__USE_SSL: "False"
      AUTHENTIK_EMAIL__FROM: "authentik@{{ tenant_domain | default('dev.local') }}"
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ authentik_mem_limit | default(docker_mem_limit_critical) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

  authentik-worker:
    image: ghcr.io/goauthentik/server:{{ authentik_version | default('2025.2') }}
    command: worker
    restart: unless-stopped
    volumes:
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/media:/media
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/templates:/templates
      - {{ authentik_data_dir | default(ansible_facts['env']['HOME'] + '/authentik') }}/certs:/certs
      - {{ stacks_dir }}/infra/authentik/blueprints:/blueprints/custom:ro
    environment:
      AUTHENTIK_SECRET_KEY: "{{ authentik_secret_key }}"
      AUTHENTIK_REDIS__HOST: redis
      AUTHENTIK_REDIS__PASSWORD: "{{ redis_password | default(global_password_prefix + '_pw_redis') }}"
      AUTHENTIK_POSTGRESQL__HOST: postgresql
      AUTHENTIK_POSTGRESQL__USER: "{{ authentik_db_user | default('authentik') }}"
      AUTHENTIK_POSTGRESQL__NAME: "{{ authentik_db_name | default('authentik') }}"
      AUTHENTIK_POSTGRESQL__PASSWORD: "{{ authentik_db_password }}"
      # Viz server — zavirat DB spojeni po requestu, jinak worker drzi
      # vlastni idle pool navrchu gunicorn poolu a spolecne zahltili
      # max_connections.
      AUTHENTIK_POSTGRESQL__CONN_MAX_AGE: "{{ authentik_pg_conn_max_age | default(0) }}"
      AUTHENTIK_POSTGRESQL__CONN_HEALTH_CHECKS: "true"
      AUTHENTIK_WORKER__PROCESSES: "{{ authentik_worker_processes | default(1) }}"
      AUTHENTIK_WORKER__THREADS: "{{ authentik_worker_threads | default(2) }}"
{% if install_mailpit | default(false) %}
      # ── SMTP relay → Mailpit (worker sends most emails) ────────────────────
      AUTHENTIK_EMAIL__HOST: "host.docker.internal"
      AUTHENTIK_EMAIL__PORT: "1025"
      AUTHENTIK_EMAIL__USERNAME: ""
      AUTHENTIK_EMAIL__PASSWORD: ""
      AUTHENTIK_EMAIL__USE_TLS: "False"
      AUTHENTIK_EMAIL__USE_SSL: "False"
      AUTHENTIK_EMAIL__FROM: "authentik@{{ tenant_domain | default('dev.local') }}"
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    healthcheck:
      # The upstream image ships a built-in healthcheck that fires immediately
      # after start. On a blank run the worker must run DB migrations first;
      # the check fails during that window and makes `docker compose up --wait`
      # return rc=1 for the whole infra stack. A 120s start_period covers
      # even slow cold-start migrations without silencing the healthcheck
      # entirely — the worker is still marked unhealthy if it crashes later.
      start_period: 120s
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ authentik_worker_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
