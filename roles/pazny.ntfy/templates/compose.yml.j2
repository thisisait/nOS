# =============================================================================
# pazny.ntfy — compose override fragment (push notifications server)
# Merged do `docker compose up iiab` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/iiab/overrides/*.yml.
#
# Nedeklaruje top-level networks: — iiab_net je definovan v base
# templates/stacks/iiab/docker-compose.yml.j2.
# =============================================================================

services:
  ntfy:
    image: binwiederhier/ntfy:{{ ntfy_version | default('v2.21.0') }}
    restart: unless-stopped
    command: ["serve"]
    ports:
{% if services_lan_access | default(false) %}
      - "{{ ntfy_port | default(2586) }}:80"
{% else %}
      - "127.0.0.1:{{ ntfy_port | default(2586) }}:80"
{% endif %}
    volumes:
      - {{ ntfy_data_dir }}:/var/cache/ntfy
      - {{ ntfy_data_dir }}/server.yml:/etc/ntfy/server.yml:ro
    environment:
      TZ: "{{ system_timezone | default('Europe/Prague') }}"
    healthcheck:
      test: ["CMD-SHELL", "wget -q --tries=1 http://localhost:80/v1/health -O - | grep -Fq \"\\\"healthy\\\":true\" || exit 1"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 40s
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ ntfy_mem_limit | default(docker_mem_limit_light | default('512m')) }}
    cpus: {{ ntfy_cpus | default(docker_cpus_light | default('0.5')) }}
