# =============================================================================
# pazny.puter - compose override fragment
# Merged into `docker compose -p iiab up` in tasks/stacks/stack-up.yml via
# ansible.builtin.find over {{ stacks_dir }}/iiab/overrides/*.yml.
#
# Does not declare top-level networks: - iiab_net and {{ stacks_shared_network }}
# are defined in the base templates/stacks/iiab/docker-compose.yml.j2.
#
# The build context points at playbook_dir/files/puter, which stays in place
# (Dockerfile + CORS patches). The role does not take over files/ as its context.
# =============================================================================

services:
  # -- Puter - cloud OS web desktop -------------------------------------------
  puter:
    build:
      context: {{ playbook_dir }}/files/puter
      dockerfile: Dockerfile
    image: nos/puter:{{ puter_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ puter_port | default(5050) }}:4100"
{% else %}
      - "127.0.0.1:{{ puter_port | default(5050) }}:4100"
{% endif %}
    environment:
      PUID: "{{ ansible_facts['user_uid'] }}"
      PGID: "{{ ansible_facts['user_gid'] }}"
      TZ: "Europe/Prague"
    volumes:
      - {{ puter_config_dir | default(ansible_facts['env']['HOME'] + '/puter/config') }}:/etc/puter
      - {{ puter_data_dir | default(ansible_facts['env']['HOME'] + '/puter') }}/data:/var/puter
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider --header='Host: {{ puter_domain | default('os' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}' http://127.0.0.1:4100/ || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 60s
    networks:
      - iiab_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ puter_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
