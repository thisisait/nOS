# =============================================================================
# pazny.uptime_kuma — compose override fragment
# Merged into `docker compose up iiab` in tasks/stacks/stack-up.yml via
# ansible.builtin.find over {{ stacks_dir }}/iiab/overrides/*.yml.
#
# Does not declare top-level networks: — iiab_net is defined in the base
# templates/stacks/iiab/docker-compose.yml.j2.
#
# SSO: no OIDC env vars — Uptime Kuma v1.x doesn't support native OIDC.
# Auth is gated at the Nginx layer via the Authentik forward_auth outpost.
# Revisit when Uptime Kuma v2.x ships stable OIDC.
# =============================================================================

services:
  uptime-kuma:
    image: louislam/uptime-kuma:{{ uptime_kuma_version | default('1') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ uptime_kuma_port | default(3001) }}:3001"
    volumes:
      - {{ uptime_kuma_data_dir }}:/app/data
    networks:
      - iiab_net
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ uptime_kuma_mem_limit | default(docker_mem_limit_light) }}
    cpus: {{ docker_cpus_light | default('0.5') }}
