# =============================================================================
# pazny.grafana — compose override fragment
# Merged do `docker compose -p observability up` v tasks/stacks/core-up.yml
# pres ansible.builtin.find nad {{ stacks_dir }}/observability/overrides/*.yml.
#
# Nedeklaruje top-level networks: — observability_net a
# {{ stacks_shared_network }} jsou definovane v base
# templates/stacks/observability/docker-compose.yml.j2.
#
# Provisioning soubory (datasources/all.yml, dashboards/all.yml) jsou
# stale renderovane z core-up.yml do {{ stacks_dir }}/observability/
# grafana/provisioning/ — nebyly presunute do role files/, protoze
# zavisi na play-level promennych (authentik_oidc_*, service registry).
# =============================================================================

services:
  grafana:
    image: grafana/grafana:{{ grafana_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ grafana_port | default(3000) }}:3000"
{% else %}
      - "127.0.0.1:{{ grafana_port | default(3000) }}:3000"
{% endif %}
    volumes:
      - {{ grafana_data_dir | default(stacks_dir + '/observability/grafana/data') }}:/var/lib/grafana
      - {{ stacks_dir }}/observability/grafana/provisioning:/etc/grafana/provisioning:ro
      - {{ ansible_facts['env']['HOME'] }}/observability/dashboards:/var/lib/grafana/dashboards:ro
{% if install_wing | default(install_php | default(true)) %}
      # Wing SQLite — read-only mount of data/ dir (needs .db + -wal + -shm)
      # so frser-sqlite-datasource can query events / migrations_applied /
      # upgrades_applied / coexistence_tracks / patches_applied tables for
      # dashboards 99-playbook and others. Mounted RO; the datasource opens
      # with mode=ro so no locks contend with Wing's writer (bone's HMAC
      # ingest on api.dev.local/api/v1/events).
      - {{ wing_data_dir | default(ansible_facts['env']['HOME'] + '/wing/app/data') }}:/var/lib/grafana/wing:ro
{% endif %}
{% if install_authentik | default(false) %}
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/etc/grafana/mkcert-ca.crt:ro
{% endif %}
    environment:
      GF_SECURITY_ADMIN_USER: "{{ grafana_admin_user | default('admin') }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ grafana_admin_password | default(global_password_prefix + '_pw_grafana') }}"
      GF_SERVER_DOMAIN: "{{ grafana_domain | default('grafana' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
      GF_SERVER_ROOT_URL: "https://{{ grafana_domain | default('grafana' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
      GF_ANALYTICS_REPORTING_ENABLED: "false"
      GF_ANALYTICS_CHECK_FOR_UPDATES: "false"
      GF_USERS_ALLOW_SIGN_UP: "false"
      GF_SECURITY_ALLOW_EMBEDDING: "true"
{% if install_wing | default(install_php | default(true)) %}
      # Auto-install the community SQLite datasource plugin so dashboards
      # (99-playbook et al.) can query Wing's events table directly.
      # Signed community plugin; Grafana 11+ tolerates it without an extra
      # allow_loading_unsigned_plugins entry.
      GF_INSTALL_PLUGINS: "frser-sqlite-datasource"
{% endif %}
{% if install_authentik | default(false) %}
      # ── Authentik SSO (OIDC) ───────────────────────────────────────────────
      GF_AUTH_GENERIC_OAUTH_ENABLED: "true"
      GF_AUTH_GENERIC_OAUTH_NAME: "Authentik"
      GF_AUTH_GENERIC_OAUTH_CLIENT_ID: "{{ authentik_oidc_grafana_client_id }}"
      GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET: "{{ authentik_oidc_grafana_client_secret }}"
      GF_AUTH_GENERIC_OAUTH_SCOPES: "openid email profile"
      GF_AUTH_GENERIC_OAUTH_AUTH_URL: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/application/o/authorize/"
      GF_AUTH_GENERIC_OAUTH_TOKEN_URL: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/application/o/token/"
      GF_AUTH_GENERIC_OAUTH_API_URL: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/application/o/userinfo"
      GF_AUTH_GENERIC_OAUTH_ALLOW_SIGN_UP: "true"
      GF_AUTH_GENERIC_OAUTH_USE_PKCE: "true"
      GF_AUTH_GENERIC_OAUTH_EMAIL_ATTRIBUTE_PATH: "email"
      GF_AUTH_GENERIC_OAUTH_LOGIN_ATTRIBUTE_PATH: "preferred_username"
      GF_AUTH_GENERIC_OAUTH_NAME_ATTRIBUTE_PATH: "name"
      GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_PATH: "contains(groups[*], 'nos-admins') && 'Admin' || 'Viewer'"
      GF_AUTH_GENERIC_OAUTH_SKIP_ORG_ROLE_SYNC: "false"
      GF_AUTH_GENERIC_OAUTH_TLS_CLIENT_CA: "/etc/grafana/mkcert-ca.crt"
      GF_AUTH_SIGNOUT_REDIRECT_URL: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/application/o/grafana/end-session/"
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:3000/api/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% if install_authentik | default(false) %}
      - "{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}:host-gateway"
{% endif %}
    networks:
      - observability_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ grafana_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

{# ───────────────────────────────────────────────────────────────────────────
   Exporter fleet (Sprint 1 Wave 1 — observability expansion)
   ───────────────────────────────────────────────────────────────────────────
   All exporters join observability_net + {{ stacks_shared_network }}. The
   shared network is the bridge to infra-stack services (postgres, mariadb,
   redis), which also advertise themselves on stacks_shared_network. That
   avoids the need to declare infra_net here (it's a per-project bridge and
   isn't exposed externally).

   Scrape configs for each target live in files/observability/alloy/config.alloy.j2
   (one prometheus.scrape block per exporter, gated by alloy_scrape_*_exporter).
   #}

{% if install_postgresql | default(false) %}
  # ── Postgres exporter ────────────────────────────────────────────────────
  postgres-exporter:
    image: prometheuscommunity/postgres-exporter:{{ postgres_exporter_version | default('v0.15.0') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ postgres_exporter_port | default(9187) }}:9187"
    environment:
      DATA_SOURCE_NAME: "postgresql://{{ postgresql_root_user | default('postgres') }}:{{ postgresql_root_password | default(global_password_prefix + '_pw_postgresql') }}@postgresql:5432/postgres?sslmode=disable"
      PG_EXPORTER_EXTEND_QUERY_PATH: ""
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:9187/metrics"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    networks:
      - observability_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ docker_mem_limit_light | default('512m') }}
    cpus: {{ docker_cpus_light | default('0.5') }}
{% endif %}

{% if install_mariadb | default(false) %}
  # ── MariaDB / MySQL exporter ─────────────────────────────────────────────
  # Needs the `mysqld_exporter` user seeded in mariadb_users (priv:
  # PROCESS, REPLICATION CLIENT, SELECT). Connection string uses the
  # MySQL-compatible DSN (user:pass@(host:port)/).
  mysqld-exporter:
    image: prom/mysqld-exporter:{{ mysqld_exporter_version | default('v0.15.1') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ mysqld_exporter_port | default(9104) }}:9104"
    command:
      - "--mysqld.address=mariadb:3306"
      - "--mysqld.username=mysqld_exporter"
      - "--collect.info_schema.processlist"
      - "--collect.info_schema.innodb_metrics"
      - "--collect.global_status"
      - "--collect.global_variables"
      - "--collect.slave_status"
    environment:
      MYSQLD_EXPORTER_PASSWORD: "{{ mysqld_exporter_password | default(global_password_prefix + '_pw_mysqld_exporter') }}"
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:9104/metrics"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    networks:
      - observability_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ docker_mem_limit_light | default('512m') }}
    cpus: {{ docker_cpus_light | default('0.5') }}
{% endif %}

{% if redis_docker | default(false) %}
  # ── Redis exporter ───────────────────────────────────────────────────────
  redis-exporter:
    image: oliver006/redis_exporter:{{ redis_exporter_version | default('v1.58.0') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ redis_exporter_port | default(9121) }}:9121"
    environment:
      REDIS_ADDR: "redis://redis:6379"
      REDIS_PASSWORD: "{{ redis_password | default(global_password_prefix + '_pw_redis') }}"
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:9121/metrics"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    networks:
      - observability_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ docker_mem_limit_light | default('512m') }}
    cpus: {{ docker_cpus_light | default('0.5') }}
{% endif %}

  # ── cAdvisor — Docker container resource metrics ────────────────────────
  # Mounts the Docker socket + host cgroup paths. On macOS Docker Desktop the
  # root "/" bind is a passthrough to the VM; cAdvisor still reports per-
  # container CPU/RAM/net/fs from /var/lib/docker.
  cadvisor:
    image: gcr.io/cadvisor/cadvisor:{{ cadvisor_version | default('v0.49.1') }}
    restart: unless-stopped
    privileged: true
    ports:
      - "127.0.0.1:{{ cadvisor_port | default(8080) }}:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    command:
      - "--housekeeping_interval=30s"
      - "--docker_only=true"
      - "--store_container_labels=false"
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8080/healthz"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    networks:
      - observability_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ cadvisor_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_light | default('0.5') }}

  # ── Blackbox exporter — HTTP/TCP probes ─────────────────────────────────
  # Module definitions (http_2xx, tcp_connect, …) live in
  # files/observability/blackbox/config.yml. Prometheus scrape targets for
  # individual URLs are owned by A2 in the prometheus rules/config dir.
  blackbox-exporter:
    image: prom/blackbox-exporter:{{ blackbox_exporter_version | default('v0.25.0') }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ blackbox_exporter_port | default(9115) }}:9115"
    volumes:
      - {{ stacks_dir }}/observability/blackbox/config.yml:/etc/blackbox_exporter/config.yml:ro
    command:
      - "--config.file=/etc/blackbox_exporter/config.yml"
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:9115/-/healthy"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - observability_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    mem_limit: {{ docker_mem_limit_light | default('512m') }}
    cpus: {{ docker_cpus_light | default('0.5') }}
