# =============================================================================
# pazny.mariadb — compose override fragment
# Merged into `docker compose up` by tasks/stacks/core-up.yml via
# ansible.builtin.find across {{ stacks_dir }}/infra/overrides/*.yml.
#
# Does not declare top-level networks: — infra_net and {{ stacks_shared_network }}
# are defined in base templates/stacks/infra/docker-compose.yml.j2.
# Docker compose merge semantics allow referencing external networks as long
# as any of the merged files defines them.
# =============================================================================

services:
  mariadb:
    image: mariadb:{{ mariadb_version | default('lts') }}
    hostname: mariadb
    restart: unless-stopped
    # InnoDB DDL workaround for Apple Silicon Docker Desktop + VirtIOFS bind
    # mount: the default --innodb-flush-method=O_DIRECT triggers a server
    # crash mid-FK-ALTER (BookStack migration #10 is the canonical reproducer)
    # when the data dir is bind-mounted from macOS (/Volumes/SSD1TB or ~/...).
    # Switching to fsync routes writes through the kernel page cache, sidestepping
    # the VirtIOFS / O_DIRECT sync race. --skip-innodb-doublewrite is safe in dev
    # (Docker Desktop's volume layer already does its own write-ordering) and
    # halves the I/O on every commit — major boost on the dev box.
    command:
      - "--innodb-flush-method=fsync"
      - "--skip-innodb-doublewrite"
    ports:
      - "127.0.0.1:{{ mariadb_port | default(3306) }}:3306"
    volumes:
      - {{ mariadb_data_dir | default(ansible_facts['env']['HOME'] + '/mariadb/data') }}:/var/lib/mysql
    environment:
      MARIADB_ROOT_PASSWORD: "{{ mariadb_root_password }}"
      MARIADB_ROOT_HOST: "%"
      MARIADB_CHARACTER_SET_SERVER: utf8mb4
      MARIADB_COLLATION_SERVER: utf8mb4_unicode_ci
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ mariadb_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
