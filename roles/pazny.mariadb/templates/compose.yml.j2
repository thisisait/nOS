# =============================================================================
# pazny.mariadb — compose override fragment
# Merged into `docker compose up` by tasks/stacks/core-up.yml via
# ansible.builtin.find across {{ stacks_dir }}/infra/overrides/*.yml.
#
# Does not declare top-level networks: — infra_net and {{ stacks_shared_network }}
# are defined in base templates/stacks/infra/docker-compose.yml.j2.
# Docker compose merge semantics allow referencing external networks as long
# as any of the merged files defines them.
# =============================================================================

services:
  mariadb:
    image: mariadb:{{ mariadb_version | default('lts') }}
    hostname: mariadb
    restart: unless-stopped
    # Performance tuning (safe to keep across volume backends).
    command:
      - "--innodb-flush-method=fsync"     # see commit history for why
      - "--skip-innodb-doublewrite"        # halves write I/O; Docker volume layer provides own ordering
    ports:
      - "127.0.0.1:{{ mariadb_port | default(3306) }}:3306"
    # IMPORTANT: data lives in a Docker NAMED VOLUME, not a bind mount.
    # Apple Silicon Docker Desktop's VirtIOFS layer crashes the InnoDB engine
    # mid-FK-ALTER (BookStack migration #10 is the canonical reproducer)
    # when /var/lib/mysql is backed by a host bind-mount; the crash leaves
    # orphan tablespace entries in the data dictionary. fsync + skip-doublewrite
    # tuning did not help — the OS-level error is OS error 71 (EPROTO) on
    # the .ibd file, which is a VirtIOFS protocol issue, not an InnoDB one.
    # Using a named volume routes I/O through Docker's overlayfs inside the
    # Linux VM and the bug disappears.
    # Trade-off: data is no longer browsable at {{ mariadb_data_dir }} on
    # the host. Backups must use mariadb-dump (see upgrades/mariadb.yml).
    # `docker compose down --volumes` (used by blank-reset.yml) wipes both
    # styles, so the blank-reset path keeps working.
    volumes:
      - mariadb_data:/var/lib/mysql
    environment:
      MARIADB_ROOT_PASSWORD: "{{ mariadb_root_password }}"
      MARIADB_ROOT_HOST: "%"
      MARIADB_CHARACTER_SET_SERVER: utf8mb4
      MARIADB_COLLATION_SERVER: utf8mb4_unicode_ci
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
    networks:
      - infra_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ mariadb_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}

# Named volume declaration — Docker Compose merges per-file `volumes:` blocks,
# so this shows up alongside any other top-level volumes from the base
# infra/docker-compose.yml.j2 or other role overrides.
volumes:
  mariadb_data:
    name: mariadb_data        # explicit name so it survives `compose -p infra down` without --volumes
