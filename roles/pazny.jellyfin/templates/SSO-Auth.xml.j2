<?xml version="1.0" encoding="utf-8"?>
{#
  SSO-Auth plugin configuration for jellyfin-plugin-sso ({{ jellyfin_sso_plugin_version }}).

  Schema authority: PluginConfiguration.cs at
  https://github.com/9p4/jellyfin-plugin-sso/blob/v{{ jellyfin_sso_plugin_version }}/SSO-Auth/Config/PluginConfiguration.cs

  Critical implementation details (.NET XmlSerializer is strict on order):
    * OidConfigs / SamlConfigs are SerializableDictionary<TKey,TValue>; their
      wire format is <item><key><string/></key><value><OidConfig/></value></item>...
    * OidConfig fields must appear in declaration order (XmlSerializer is order-
      sensitive when [XmlElement] is implicit).
    * The C# field is named `FolderRoleMapping` (singular), but [XmlArray("FolderRoleMappings")]
      renames the wrapping element to PLURAL. Empty list → self-closing tag.
    * If the plugin can't deserialize, it silently falls back to an empty
      dict and overwrites this file on the next save — every login attempt
      then 400s with "Provider does not exist".
#}
<PluginConfiguration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <SamlConfigs />
  <OidConfigs>
    <item>
      <key>
        <string>{{ jellyfin_oidc_provider_name }}</string>
      </key>
      <value>
        <OidConfig>
          <OidEndpoint>{{ jellyfin_oidc_endpoint }}</OidEndpoint>
          <OidClientId>{{ jellyfin_oidc_client_id }}</OidClientId>
          <OidSecret>{{ jellyfin_oidc_client_secret }}</OidSecret>
          <Enabled>true</Enabled>
          <EnableAuthorization>true</EnableAuthorization>
          <EnableAllFolders>true</EnableAllFolders>
          <EnabledFolders />
          <AdminRoles>
{% for role in jellyfin_oidc_admin_roles %}
            <string>{{ role }}</string>
{% endfor %}
          </AdminRoles>
          <Roles>
{% for role in jellyfin_oidc_user_roles %}
            <string>{{ role }}</string>
{% endfor %}
          </Roles>
          <EnableFolderRoles>false</EnableFolderRoles>
          <EnableLiveTvRoles>false</EnableLiveTvRoles>
          <EnableLiveTv>false</EnableLiveTv>
          <EnableLiveTvManagement>false</EnableLiveTvManagement>
          <LiveTvRoles />
          <LiveTvManagementRoles />
          <FolderRoleMappings />
          <RoleClaim>groups</RoleClaim>
          <OidScopes>
            <string>openid</string>
            <string>profile</string>
            <string>email</string>
            <string>groups</string>
          </OidScopes>
          <DefaultProvider></DefaultProvider>
          <SchemeOverride>https</SchemeOverride>
          <NewPath>true</NewPath>
          <CanonicalLinks />
          <DefaultUsernameClaim>preferred_username</DefaultUsernameClaim>
          <DisableHttps>false</DisableHttps>
          <DoNotValidateEndpoints>false</DoNotValidateEndpoints>
          <DoNotValidateIssuerName>false</DoNotValidateIssuerName>
        </OidConfig>
      </value>
    </item>
  </OidConfigs>
</PluginConfiguration>
