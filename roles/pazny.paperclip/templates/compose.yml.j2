# =============================================================================
# pazny.paperclip — compose override fragment
# Merged into `docker compose -p devops up` by tasks/stacks/stack-up.yml via
# ansible.builtin.find across {{ stacks_dir }}/devops/overrides/*.yml.
#
# Does not declare top-level networks: — devops_net and {{ stacks_shared_network }}
# are defined in base templates/stacks/devops/docker-compose.yml.j2.
# =============================================================================

services:
  paperclip:
    image: ghcr.io/paperclipai/paperclip:{{ paperclip_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ paperclip_port | default(3006) }}:3100"
{% else %}
      - "127.0.0.1:{{ paperclip_port | default(3006) }}:3100"
{% endif %}
    volumes:
      - {{ paperclip_data_dir | default(ansible_facts['env']['HOME'] + '/paperclip') }}:/paperclip
{% if install_authentik | default(false) and (paperclip_native_oidc_enabled | default(false)) and (tenant_domain_is_local | default(true) | bool) %}
      # mkcert CA conditional — local TLDs only (regression class sweep 2026-05-03).
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/usr/local/share/ca-certificates/mkcert-ca.crt:ro
{% endif %}
    environment:
      HOST: "0.0.0.0"
      PORT: "3100"
      DATABASE_URL: "postgresql://{{ paperclip_db_user | default('paperclip') }}:{{ paperclip_db_password | default(global_password_prefix + '_pw_paperclip') }}@postgresql:5432/{{ paperclip_db_name | default('paperclip') }}"
      PAPERCLIP_HOME: "/paperclip"
      PAPERCLIP_DEPLOYMENT_MODE: "authenticated"
      # OpenClaw gateway URL — declared in defaults/main.yml and
      # default.config.yml but previously never injected into the container
      # (dead variable). Wire it up so Paperclip can reach the agent.
      PAPERCLIP_OPENCLAW_URL: "{{ paperclip_openclaw_url | default('http://host.docker.internal:' ~ (openclaw_gateway_port | default(18789))) }}"
      # BetterAuth session signing key. Default derives from the deterministic
      # global_password_prefix (see default.config.yml) — must NOT fall back to
      # lookup('pipe', 'openssl rand ...') because that re-rolls the secret on
      # every playbook run and invalidates all active sessions.
      BETTER_AUTH_SECRET: "{{ paperclip_auth_secret | default(global_password_prefix ~ '_pw_paperclip_auth') }}"
      BETTER_AUTH_TRUSTED_ORIGINS: "https://{{ paperclip_domain | default('paperclip' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}{{ ',' + (service_extra_hosts | default([]) | map('regex_replace', '^(.*)$', 'https://\\1') | join(',')) if (service_extra_hosts | default([]) | length > 0) else '' }}"
{% if install_authentik | default(false) and (paperclip_native_oidc_enabled | default(false)) %}
      # ── Authentik SSO (native OIDC via BetterAuth genericOAuth plugin) ─────
      # NOTE (Sprint 2c, 2026-04-22): The upstream Paperclip image does NOT
      # currently honour these env vars — BetterAuth's generic-OAuth plugin
      # must be registered in application code, not via env. These are
      # staged for when upstream adds env-driven OIDC config (or nOS forks
      # Paperclip to wire BetterAuth's genericOAuth provider from env).
      # Access control is therefore enforced at the Nginx layer via the
      # Authentik forward_auth outpost (proxy auth + RBAC tier).
      # Toggle `paperclip_native_oidc_enabled: true` to surface the env vars
      # for a fork / future upstream version.
      BETTER_AUTH_OIDC_ENABLED: "true"
      BETTER_AUTH_OIDC_ISSUER: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/application/o/paperclip/"
      BETTER_AUTH_OIDC_CLIENT_ID: "{{ authentik_oidc_paperclip_client_id | default('nos-paperclip') }}"
      BETTER_AUTH_OIDC_CLIENT_SECRET: "{{ authentik_oidc_paperclip_client_secret | default(global_password_prefix ~ '_pw_oidc_paperclip') }}"
      BETTER_AUTH_OIDC_REDIRECT_URI: "https://{{ paperclip_domain | default('paperclip' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}/api/auth/oauth/oidc/callback"
      BETTER_AUTH_OIDC_DISPLAY_NAME: "Authentik"
      BETTER_AUTH_OIDC_SCOPES: "openid profile email"
{% if tenant_domain_is_local | default(true) | bool %}
      NODE_EXTRA_CA_CERTS: "/usr/local/share/ca-certificates/mkcert-ca.crt"
{% endif %}
{% endif %}
{% if install_authentik | default(false) %}
    extra_hosts:
      - "{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}:host-gateway"
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:3100/ || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 10
      start_period: 30s
    networks:
      - devops_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ paperclip_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
