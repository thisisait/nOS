# =============================================================================
# pazny.paperclip — compose override fragment
# Merged do `docker compose -p devops up` v tasks/stacks/stack-up.yml pres
# ansible.builtin.find nad {{ stacks_dir }}/devops/overrides/*.yml.
#
# Nedeklaruje top-level networks: — devops_net a {{ stacks_shared_network }}
# jsou definovane v base templates/stacks/devops/docker-compose.yml.j2.
# =============================================================================

services:
  paperclip:
    image: ghcr.io/paperclipai/paperclip:{{ paperclip_version | default('latest') }}
    restart: unless-stopped
    ports:
{% if services_lan_access | default(false) %}
      - "{{ paperclip_port | default(3006) }}:3100"
{% else %}
      - "127.0.0.1:{{ paperclip_port | default(3006) }}:3100"
{% endif %}
    volumes:
      - {{ paperclip_data_dir | default(ansible_facts['env']['HOME'] + '/paperclip') }}:/paperclip
    environment:
      HOST: "0.0.0.0"
      PORT: "3100"
      DATABASE_URL: "postgresql://{{ paperclip_db_user | default('paperclip') }}:{{ paperclip_db_password | default(global_password_prefix + '_pw_paperclip') }}@postgresql:5432/{{ paperclip_db_name | default('paperclip') }}"
      PAPERCLIP_HOME: "/paperclip"
      PAPERCLIP_DEPLOYMENT_MODE: "authenticated"
      BETTER_AUTH_SECRET: "{{ paperclip_auth_secret | default(lookup('pipe', 'openssl rand -hex 32')) }}"
      BETTER_AUTH_TRUSTED_ORIGINS: "https://{{ paperclip_domain | default('paperclip.dev.local') }}{{ ',' + (service_extra_hosts | default([]) | map('regex_replace', '^(.*)$', 'https://\\1') | join(',')) if (service_extra_hosts | default([]) | length > 0) else '' }}"
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:3100/ || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 10
      start_period: 30s
    networks:
      - devops_net
      - {{ stacks_shared_network }}
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"
    mem_limit: {{ paperclip_mem_limit | default(docker_mem_limit_standard) }}
    cpus: {{ docker_cpus_standard | default('1.0') }}
