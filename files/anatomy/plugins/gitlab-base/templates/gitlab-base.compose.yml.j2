# =============================================================================
# gitlab-base — compose-extension fragment (D2 2026-05-05).
#
# Rendered into {{ stacks_dir }}/devops/overrides/gitlab-base.yml at
# pre_compose. Carries: mkcert CA mount conditional + _NOS_PLUGIN marker +
# authentik:host-gateway extra_host.
#
# GITLAB_OMNIBUS_CONFIG is intentionally NOT in this plugin (D2 decision):
# Omnibus config is a monolithic Ruby-string env var — Compose file-merge
# replaces the whole key (last-writer wins). Override files are loaded
# alphabetically: `gitlab-base.yml` < `gitlab.yml` so the role's file wins.
# The role keeps the full GITLAB_OMNIBUS_CONFIG (infra + conditional Authentik
# omniauth block) because splitting a monolithic string across files is unsafe.
# The plugin.yml authentik: block is still the SSO source-of-truth for the
# Authentik blueprint; only the compose-side wiring stays role-side.
# =============================================================================

services:
  gitlab:
{% if install_authentik | default(false) and (tenant_domain_is_local | default(true) | bool) %}
    # mkcert CA conditional — local TLDs only.
    volumes:
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/etc/gitlab/trusted-certs/mkcert-ca.crt:ro
{% endif %}
    environment:
      _NOS_PLUGIN: "gitlab-base"
{% if install_authentik | default(false) %}
    extra_hosts:
      - "{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}:host-gateway"
{% endif %}
