{# nodered-base — compose-extension stub (β1.B native_oidc, refactored 2026-05-07).

   Pre-β1.B this template emitted Traefik docker-provider labels with
   `authentik@file` forward-auth middleware. β1.B (2026-05-05) flipped
   Node-RED to native_oidc (passport-openidconnect adminAuth wired into
   /data/settings.js inside the role). The role-emitted Traefik labels
   then COLLIDED with the file-provider entry derived from
   state/manifest.yml — duplicate routers with same Host rule, one with
   `authentik@file` and one without, Traefik picked nondeterministically
   → 404 (smoke probe failure 2026-05-07 12:25).

   Fix (2026-05-07): for native_oidc services, file-provider's auto-derived
   router (state/manifest.yml + traefik_auth_modes:nodered=oidc → no
   middleware) is the canonical route. Plugin compose-extensions must NOT
   emit Traefik labels for Tier-1 services.

   This file remains as an _NOS_PLUGIN env stub (anatomy P0.12) so the
   plugin identity surfaces in `docker inspect`. CI gate
   tests/anatomy/test_native_oidc_no_authentik_middleware.py blocks any
   future re-introduction of the authentik@file label class.
#}
services:
  nodered:
{% if install_authentik | default(false) and (tenant_domain_is_local | default(true) | bool) %}
    # mkcert CA conditional — local TLDs only (regression class sweep 2026-05-03).
    volumes:
      - {{ stacks_dir }}/shared-certs/rootCA.pem:/etc/ssl/certs/mkcert-rootCA.pem:ro
{% endif %}
    environment:
      # Defensive sentinel — pin the plugin slug for any tool that
      # introspects containers via `docker inspect` (P0.12 doctrine).
      _NOS_PLUGIN: "nodered-base"
{% if install_authentik | default(false) and (tenant_domain_is_local | default(true) | bool) %}
      NODE_EXTRA_CA_CERTS: "/etc/ssl/certs/mkcert-rootCA.pem"
{% endif %}
{% if install_authentik | default(false) %}
    extra_hosts:
      - "{{ authentik_domain }}:host-gateway"
{% endif %}