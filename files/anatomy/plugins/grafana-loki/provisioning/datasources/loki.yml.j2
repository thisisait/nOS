# ==============================================================================
# Grafana datasource — Loki (rendered by grafana-loki composition plugin)
# Generated by Ansible / plugin loader — manual edits will be overwritten.
# ==============================================================================

apiVersion: 1

datasources:
  - name: Loki
    type: loki
    uid: loki
    access: proxy
    url: http://loki:{{ loki_port | default(3100) }}
    jsonData:
      derivedFields:
        - datasourceUid: tempo
          matcherRegex: '"trace_id":"(\w+)"'
          name: TraceID
          url: '$${__value.raw}'
    version: 1
    editable: false
