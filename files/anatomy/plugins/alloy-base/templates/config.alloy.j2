// ==============================================================================
// Grafana Alloy — minimal core configuration (alloy-base plugin)
// Generated by the nOS plugin loader — manual edits will be overwritten.
//
// This file is intentionally MINIMAL. Composition plugins (Phase 3) extend it:
//   alloy-host-metrics    → prometheus.exporter.unix + per-exporter scrapes
//   alloy-docker-metrics  → discovery.docker + loki.source.docker
//   alloy-syslog          → local.file_match + loki.source.file (nginx, php-fpm,
//                                                                agents, brew svcs)
// What stays HERE forever (the "core"):
//   - logging
//   - alloy self-scrape (so we can see the collector itself in Grafana)
//   - prometheus.remote_write default endpoint (every scrape `forward_to`s here)
//   - loki.write default endpoint (every log source `forward_to`s here)
//   - OTLP receiver (gRPC + HTTP) → Tempo
// ==============================================================================

// ── Logging ───────────────────────────────────────────────────────────────────
logging {
  level  = "warn"
  format = "logfmt"
}

// ─────────────────────────────────────────────────────────────────────────────
// METRICS — self-scrape + remote_write target
// ─────────────────────────────────────────────────────────────────────────────

// Self-monitoring: Alloy's own internal metrics (component health, WAL depth,
// scrape latency). Composition plugins reuse `prometheus.remote_write.default`
// as their `forward_to` sink.
prometheus.scrape "alloy_self" {
  targets = [{
    __address__ = "localhost:{{ alloy_ui_port | default(12345) }}",
  }]
  forward_to      = [prometheus.remote_write.default.receiver]
  job_name        = "alloy"
  scrape_interval = "15s"
}

// Remote-write to Prometheus (the canonical metrics sink for the LGTM stack).
prometheus.remote_write "default" {
  endpoint {
    url = "http://localhost:{{ prometheus_port | default(9090) }}/api/v1/write"
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// LOGS — write target (Loki)
// ─────────────────────────────────────────────────────────────────────────────
// No log sources here in the base config — composition plugins
// (alloy-syslog / alloy-docker-metrics) declare local.file_match +
// loki.source.* and forward to this writer.

loki.write "default" {
  endpoint {
    url = "http://localhost:{{ loki_port | default(3100) }}/loki/api/v1/push"
  }
  external_labels = {
    host = "{{ observability_hostname | default(ansible_facts['hostname'] | default('localhost')) }}",
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// TRACES (OTLP) → Tempo
// ─────────────────────────────────────────────────────────────────────────────
// Applications send traces via the OpenTelemetry SDK. Alloy listens on
// alloy_otlp_*_port (4317/4318) and forwards to Tempo on tempo_otlp_grpc_port
// (4327 default — Tempo containerised, accessed via host port mapping).

otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:{{ alloy_otlp_grpc_port | default(4317) }}"
  }
  http {
    endpoint = "0.0.0.0:{{ alloy_otlp_http_port | default(4318) }}"
  }

  output {
    traces = [otelcol.exporter.otlp.tempo.input]
  }
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "localhost:{{ tempo_otlp_grpc_port | default(4327) }}"
    tls {
      insecure = true
    }
  }
}
