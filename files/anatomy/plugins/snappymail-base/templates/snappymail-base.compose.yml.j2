{# snappymail-base — Traefik forward-auth labels for snappymail.

Renders into:
  {{ stacks_dir }}/iiab/overrides/snappymail-base.yml

Docker Compose merges this with the role's primary override fragment.
The `authentik@file` middleware lives in the Traefik file provider
(`roles/pazny.traefik/templates/dynamic/middlewares.yml.j2`) — this
plugin only wires services INTO that middleware.
#}
services:
  snappymail:
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.snappymail.rule=Host(`{{ snappymail_domain }}`)"
      - "traefik.http.routers.snappymail.entrypoints=websecure"
      - "traefik.http.routers.snappymail.tls=true"
      - "traefik.http.routers.snappymail.middlewares=authentik@file,security-headers@file,compress@file"
      - "traefik.http.services.snappymail.loadbalancer.server.port={{ snappymail_port }}"