# =============================================================================
# Grafana Tempo datasource — provisioned by grafana-tempo composition plugin
# Generated by Ansible / plugin loader — manual edits will be overwritten.
# =============================================================================

apiVersion: 1

datasources:
  - name: Tempo
    type: tempo
    uid: tempo
    access: proxy
    url: http://tempo:{{ tempo_http_port | default(3200) }}
    jsonData:
      httpMethod: GET
      # Service map: link spans → Prometheus metrics by service.name
      serviceMap:
        datasourceUid: prometheus
      nodeGraph:
        enabled: true
      # Trace-to-logs: jump from a span to the matching Loki log line by trace_id
      lokiSearch:
        datasourceUid: loki
      tracesToLogsV2:
        datasourceUid: loki
        spanStartTimeShift: '-30m'
        spanEndTimeShift: '30m'
        tags:
          - key: service.name
            value: service
        filterByTraceID: true
        filterBySpanID: false
      traceQuery:
        timeShiftEnabled: true
        spanStartTimeShift: '-30m'
        spanEndTimeShift: '30m'
    version: 1
    editable: false
