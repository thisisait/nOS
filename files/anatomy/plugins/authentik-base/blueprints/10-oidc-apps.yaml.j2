# yaml-language-server: $schema=https://goauthentik.io/blueprints/schema.json
# ── nOS OAuth2 / Proxy providers + applications ─────────────────────────
# D1.2 (2026-05-05): blueprint switched from iterating
# `authentik_oidc_apps | default([])` (central pre-Q2 list in
# default.config.yml) to `inputs.clients | default([])` — the per-plugin
# `authentik:` blocks harvested by load_plugins.run_aggregators.
#
# Loader pre-renders Jinja inside each block AND filters out plugins
# whose `requires.feature_flag` is off (D1.2.a aggregator extension),
# so the `enabled` field below already reflects the live install set.
#
# Mode/provider mapping:
#   - native_oidc / oauth2     → authentik_providers_oauth2.oauth2provider
#   - header_oidc              → proxy provider (outpost forwards
#                                  REMOTE_USER/REMOTE_EMAIL to service)
#   - forward_auth / proxy     → proxy provider (pure access gate)
#
# Both header_oidc and forward_auth render as proxy providers in
# Authentik (same protocol object); the doctrine difference lives in
# the plugin manifest (`mode:`) and informs whether the service has
# per-user state. Outpost binds to all proxy providers regardless.

version: 1
metadata:
  name: nos-oidc-apps
  labels:
    managed-by: nos
    blueprint-version: "2"

{# D1.3 (2026-05-05): merge Tier-1 plugin blocks (inputs.clients, post-Q2
   per-plugin authentik:) with Tier-2 apps_runner extras (authentik_oidc_apps
   list, runtime-built from apps/<name>.yml manifests). Same blueprint
   handles both shapes — proven by aggregator-dry-run before the cutover. #}
{% set _all_clients = (inputs.clients | default([])) + (authentik_oidc_apps | default([])) %}

entries:
{% for c in _all_clients %}
{% if c.enabled | default(false) | bool %}
{%- set _type_legacy = c.type | default(none) -%}
{%- set _mode = c.mode | default(c.provider_type) | default('native_oidc' if _type_legacy != 'proxy' else 'forward_auth') -%}
{%- set _is_proxy = _mode in ['forward_auth', 'proxy', 'header_oidc'] or _type_legacy == 'proxy' -%}
{%- set _name = c.name | default(c.slug | replace('-', ' ') | title) -%}
{%- set _redirects = c.redirect_uris if (c.redirect_uris is iterable and c.redirect_uris is not string) else ([c.redirect_uris] if c.redirect_uris else []) -%}
{%- set _launch = c.launch_url | default(c.external_host) | default('') -%}
{% if not _is_proxy %}
  # ── {{ _name }} (OAuth2 / OIDC) ──
  - model: authentik_providers_oauth2.oauth2provider
    state: present
    identifiers:
      name: "{{ _name }}"
    attrs:
      client_type: "confidential"
      client_id: "{{ c.client_id }}"
      client_secret: "{{ c.client_secret }}"
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      access_code_validity: "minutes=10"
      access_token_validity: "minutes=10"
      refresh_token_validity: "days=30"
      sub_mode: "hashed_user_id"
      include_claims_in_id_token: true
      issuer_mode: "per_provider"
      redirect_uris:
{% for r in _redirects %}
        - matching_mode: "strict"
          url: "{{ r }}"
{% endfor %}
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, authentik Self-signed Certificate]]

  - model: authentik_core.application
    state: present
    identifiers:
      slug: "{{ c.slug }}"
    attrs:
      name: "{{ _name }}"
      meta_launch_url: "{{ _launch }}"
      provider: !Find [authentik_providers_oauth2.oauth2provider, [name, "{{ _name }}"]]
      policy_engine_mode: "any"
      open_in_new_tab: true
{% else %}
  # ── {{ _name }} ({{ _mode }} → proxy provider) ──
  - model: authentik_providers_proxy.proxyprovider
    state: present
    identifiers:
      name: "{{ _name }}"
    attrs:
      external_host: "{{ _launch }}"
      mode: "forward_single"
      internal_host_ssl_validation: false
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]

  - model: authentik_core.application
    state: present
    identifiers:
      slug: "{{ c.slug }}"
    attrs:
      name: "{{ _name }}"
      meta_launch_url: "{{ _launch }}"
      provider: !Find [authentik_providers_proxy.proxyprovider, [name, "{{ _name }}"]]
      policy_engine_mode: "any"
      open_in_new_tab: true
{% endif %}
{% endif %}
{% endfor %}

  # ── Embedded outpost: bind every proxy provider (forward_auth + header_oidc) ──
  - model: authentik_outposts.outpost
    state: present
    identifiers:
      managed: "goauthentik.io/outposts/embedded"
    attrs:
      name: "authentik Embedded Outpost"
      type: "proxy"
      providers:
{% for c in _all_clients %}
{%- set _type_legacy = c.type | default(none) -%}
{%- set _mode = c.mode | default(c.provider_type) | default('native_oidc' if _type_legacy != 'proxy' else 'forward_auth') -%}
{%- set _is_proxy = _mode in ['forward_auth', 'proxy', 'header_oidc'] or _type_legacy == 'proxy' -%}
{%- set _name = c.name | default(c.slug | replace('-', ' ') | title) -%}
{% if (c.enabled | default(false) | bool) and _is_proxy %}
        - !Find [authentik_providers_proxy.proxyprovider, [name, "{{ _name }}"]]
{% endif %}
{% endfor %}
      config:
        authentik_host: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
        authentik_host_browser: "https://{{ authentik_domain | default('auth' ~ (_host_alias_seg | default('')) ~ '.' ~ (tenant_domain | default('dev.local'))) }}"
        authentik_host_insecure: false
        log_level: "info"
        object_naming_template: "ak-outpost-%(name)s"
        docker_labels: null
        docker_network: null
        container_image: null
        kubernetes_replicas: 1
        kubernetes_namespace: "authentik"
