        "legend": { "calcs": ["last", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum by (budget) (firefly_budget_spend_current)",
          "legendFormat": "{{budget}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Budget spend (current period)",
      "type": "timeseries"
