    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "RBAC tier distribution. TODO: requires a custom recording rule or query against Authentik's Postgres DB (authentik_core_user_ak_groups). Until wired, this panel falls back to empty — placeholder expression returns 0-series vectors keyed by tier label.",
