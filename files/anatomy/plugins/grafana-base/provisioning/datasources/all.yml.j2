# ==============================================================================
# Grafana datasources provisioning (Docker stack)
# Generated by Ansible – manual edits will be overwritten
# ==============================================================================

apiVersion: 1

datasources:
  # ── Prometheus – metrics ──────────────────────────────────────────────────
  - name: Prometheus
    type: prometheus
    uid: prometheus
    access: proxy
    url: http://prometheus:{{ prometheus_port | default(9090) }}
    isDefault: true
    jsonData:
      httpMethod: POST
      exemplarTraceIdDestinations:
        - name: trace_id
          datasourceUid: tempo
    version: 1
    editable: false

  # ── Loki – logs ──────────────────────────────────────────────────────────
  - name: Loki
    type: loki
    uid: loki
    access: proxy
    url: http://loki:{{ loki_port | default(3100) }}
    jsonData:
      derivedFields:
        - datasourceUid: tempo
          matcherRegex: '"trace_id":"(\w+)"'
          name: TraceID
          url: '$${__value.raw}'
    version: 1
    editable: false

  # ── Tempo – traces ────────────────────────────────────────────────────────
  - name: Tempo
    type: tempo
    uid: tempo
    access: proxy
    url: http://tempo:{{ tempo_http_port | default(3200) }}
    jsonData:
      httpMethod: GET
      serviceMap:
        datasourceUid: prometheus
      nodeGraph:
        enabled: true
      lokiSearch:
        datasourceUid: loki
      traceQuery:
        timeShiftEnabled: true
        spanStartTimeShift: '-30m'
        spanEndTimeShift: '30m'
    version: 1
    editable: false

{% if install_wing | default(install_php | default(true)) %}
  # ── Wing SQLite – playbook events + migration / upgrade / patch history ──
  # Read-only direct SQLite read of Wing's events.db (bind-mounted into the
  # Grafana container as /var/lib/grafana/wing/wing.db). Used by the
  # 99-playbook dashboard to render ansible run history, failure counts,
  # and event timeline without needing a Loki pipeline. The mode=ro URL
  # param opens WAL-mode DB without contending with bone's writer.
  #
  # Uses the community plugin frser-sqlite-datasource, auto-installed via
  # GF_INSTALL_PLUGINS in roles/pazny.grafana/templates/compose.yml.j2.
  - name: Wing SQLite
    type: frser-sqlite-datasource
    uid: wing_sqlite
    access: proxy
    jsonData:
      path: /var/lib/grafana/wing/wing.db
      # Open read-only so we don't race with the Nette writer.
      pathOptions: "mode=ro"
    version: 1
    editable: false
{% endif %}

{% if install_influxdb | default(false) %}
  # ── InfluxDB 2.x – time-series data (Flux) ────────────────────────────────
  # Token is read from credentials.yml (influxdb_admin_token). On blank runs it
  # is written to the InfluxDB volume via DOCKER_INFLUXDB_INIT_ADMIN_TOKEN.
  # Outside of blank runs (persistent volume), the Grafana token must match
  # what InfluxDB holds in /var/lib/influxdb2 — typically identical because
  # influxdb_admin_token lives in the destructive group and is not regenerated
  # outside of blank runs.
  - name: InfluxDB
    type: influxdb
    uid: influxdb
    access: proxy
    url: http://influxdb:{{ influxdb_port | default(8086) }}
    jsonData:
      version: Flux
      organization: "{{ influxdb_org | default('nos') }}"
      defaultBucket: "{{ influxdb_bucket | default('default') }}"
      tlsSkipVerify: true
    secureJsonData:
      token: "{{ influxdb_admin_token }}"
    version: 1
    editable: false
{% endif %}
