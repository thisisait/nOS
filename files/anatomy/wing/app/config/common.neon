parameters:
	dataDir: %tempDir%/../data

application:
	errorPresenter: Error
	mapping:
		*: App\Presenters\*Presenter
		Api: App\Presenters\Api\*Presenter

session:
	expiration: 14 days

database:
	dsn: 'sqlite:%dataDir%/wing.db'

services:
	router: App\Core\RouterFactory::createRouter()

	# Repositories
	- App\Model\ComponentRepository
	- App\Model\ScanStateRepository
	- App\Model\RemediationRepository
	- App\Model\TokenRepository
	- App\Model\PentestRepository
	- App\Model\AdvisoryRepository
	- App\Model\PatchRepository

	# Hub — unified system entity (DB-backed, replaces ServiceRegistry)
	- App\Model\SystemRepository

	# State & Migration Framework
	- App\Model\BoneClient
	- App\Model\EventRepository
	- App\Model\MigrationRepository
	- App\Model\UpgradeRepository
	- App\Model\CoexistenceRepository

	# GDPR Article 30 register (Track D, 2026-04-26)
	- App\Model\GdprRepository

	# Vector DB substrate — Tier-2 Qdrant (apps/qdrant.yml).
	# Reads QDRANT_URL + QDRANT_API_KEY_RO from env (read-only key by design;
	# write path goes through Bone /api/v1/embeddings/upsert so all writes
	# carry actor attribution).
	- App\Model\QdrantClient
