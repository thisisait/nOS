<!DOCTYPE html>
<html lang="cs">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{ifset title}{include title} | {/ifset}Wing — NOS Security Research Dashboard</title>
	<link rel="stylesheet" href="/assets/style.css">
</head>
<body>

<div class="header">
	<div class="header-left">
		<div>
			<h1><a href="/" style="color:inherit">Wing</a> <span style="color:var(--text2); font-weight:400">NOS Security Research</span></h1>
			<div class="subtitle">FOSS vulnerability monitoring, autonomous pentesting, upstream patch development</div>
		</div>
	</div>
	<div class="header-right">
		<span id="headerStatus"></span>
		{if $isAuthenticated}
			<span style="color:var(--text2);font-size:12px">{$authName ?? $authUser}</span>
			<a href="https://auth.dev.local/application/o/wing/end-session/" style="font-size:12px;color:var(--text2);margin-left:4px">Odhlasit</a>
		{/if}
	</div>
</div>

<div class="tabs" id="tabs">
	<a class="tab{if $activeTab === 'hub'} active{/if}" href="/hub" data-tab="hub">Hub <span class="tab-key">0</span></a>
	<a class="tab{if $activeTab === 'overview'} active{/if}" href="/dashboard" data-tab="overview">Overview <span class="tab-key">1</span></a>
	<a class="tab{if $activeTab === 'timeline'} active{/if}" href="/dashboard#timeline" data-tab="timeline">Timeline <span class="tab-key">2</span></a>
	<a class="tab{if $activeTab === 'components'} active{/if}" href="/dashboard#components" data-tab="components">Components <span class="tab-key">3</span></a>
	<a class="tab{if $activeTab === 'pentest'} active{/if}" href="/pentest" data-tab="pentest">Pentest <span class="tab-key">4</span></a>
	<a class="tab{if $activeTab === 'remediation'} active{/if}" href="/remediation" data-tab="remediation">Remediation <span class="tab-key">5</span></a>
	<a class="tab{if $activeTab === 'inbox'} active{/if}" href="/inbox" data-tab="inbox">Inbox <span class="tab-key">7</span></a>
	<a class="tab{if $activeTab === 'approvals'} active{/if}" href="/approvals" data-tab="approvals">Approvals <span class="tab-key">8</span></a>
	<a class="tab{if $activeTab === 'audit'} active{/if}" href="/audit" data-tab="audit">Audit <span class="tab-key">9</span></a>
	{* A14: Agents tab — AIT runtime catalog + session lineage. Read-only
	   for any authenticated user; running an agent goes through the CLI or
	   a future operator-tier UI button. *}
	<a class="tab{if $activeTab === 'agents'} active{/if}" href="/agents" data-tab="agents">Agents</a>
	<a class="tab{if $activeTab === 'help'} active{/if}" href="/help" data-tab="help">Help <span class="tab-key">6</span></a>
	{* A12: Admin tab only visible to nos-providers (Tier-1). Server-side
	   guard in AdminPresenter::requireSuperAdmin is the actual gate. *}
	{if $isSuperAdmin}
		<a class="tab{if $activeTab === 'admin'} active{/if}" href="/admin" data-tab="admin" style="margin-left:auto; color:#d11; font-weight:600;">Admin</a>
	{/if}
</div>

<div class="container">
	{include content}
</div>

<script src="/assets/dashboard.js"></script>
</body>
</html>
