{
  "name": "wing-e2e",
  "private": true,
  "version": "1.0.0",
  "description": "Playwright e2e tests for Wing Hub and first-admin provisioning of nOS services",
  "scripts": {
    "install-browsers": "playwright install chromium",
    "test": "playwright test",
    "test:smoke": "playwright test --project smoke",
    "test:provisioning": "playwright test --project provisioning",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "dotenv": "^16.4.5"
  }
}
