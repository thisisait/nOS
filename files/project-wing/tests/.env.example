# Copy to tests/.env (gitignored) or inject at runtime. None are required —
# every test gracefully skips if its env is missing. Set only what you need.
#
# Global base (all service URLs default to https://<svc>.$DEV_DOMAIN)
DEV_DOMAIN=dev.local
GLASSWING_URL=https://glasswing.dev.local

# Authentik SSO — needed for authenticated Hub smoke test
# AUTHENTIK_USER=akadmin
# AUTHENTIK_PASSWORD=

# Provisioning tests. If SERVICE_ADMIN_PASSWORD is set, every provisioning
# spec uses it as fallback. Individual overrides (e.g. METABASE_ADMIN_PASSWORD)
# take precedence.
# SERVICE_ADMIN_PASSWORD=

# Per-service overrides (optional — skip what you don't provision this way)
# METABASE_URL=https://bi.dev.local
# METABASE_ADMIN_EMAIL=admin@dev.local
# METABASE_ADMIN_PASSWORD=

# JELLYFIN_URL=https://media.dev.local
# JELLYFIN_ADMIN_USER=admin
# JELLYFIN_ADMIN_PASSWORD=

# OPENWEBUI_URL=https://ai.dev.local
# OPENWEBUI_ADMIN_EMAIL=admin@dev.local
# OPENWEBUI_ADMIN_PASSWORD=

# PORTAINER_URL=https://portainer.dev.local
# PORTAINER_ADMIN_USER=admin
# PORTAINER_ADMIN_PASSWORD=

# UPTIME_KUMA_URL=http://127.0.0.1:3001
# UPTIME_KUMA_ADMIN_USER=admin
# UPTIME_KUMA_ADMIN_PASSWORD=
