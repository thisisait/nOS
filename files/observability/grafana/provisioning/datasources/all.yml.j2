# ==============================================================================
# Grafana datasources provisioning (Docker stack)
# Generated by Ansible – manual edits will be overwritten
# ==============================================================================

apiVersion: 1

datasources:
  # ── Prometheus – metrics ──────────────────────────────────────────────────
  - name: Prometheus
    type: prometheus
    uid: prometheus
    access: proxy
    url: http://prometheus:{{ prometheus_port | default(9090) }}
    isDefault: true
    jsonData:
      httpMethod: POST
      exemplarTraceIdDestinations:
        - name: trace_id
          datasourceUid: tempo
    version: 1
    editable: false

  # ── Loki – logs ──────────────────────────────────────────────────────────
  - name: Loki
    type: loki
    uid: loki
    access: proxy
    url: http://loki:{{ loki_port | default(3100) }}
    jsonData:
      derivedFields:
        - datasourceUid: tempo
          matcherRegex: '"trace_id":"(\w+)"'
          name: TraceID
          url: '$${__value.raw}'
    version: 1
    editable: false

  # ── Tempo – traces ────────────────────────────────────────────────────────
  - name: Tempo
    type: tempo
    uid: tempo
    access: proxy
    url: http://tempo:{{ tempo_http_port | default(3200) }}
    jsonData:
      httpMethod: GET
      serviceMap:
        datasourceUid: prometheus
      nodeGraph:
        enabled: true
      lokiSearch:
        datasourceUid: loki
      traceQuery:
        timeShiftEnabled: true
        spanStartTimeShift: '-30m'
        spanEndTimeShift: '30m'
    version: 1
    editable: false

{% if install_influxdb | default(false) %}
  # ── InfluxDB 2.x – time-series data (Flux) ────────────────────────────────
  # Token is read from credentials.yml (influxdb_admin_token). On blank runs it
  # is written to the InfluxDB volume via DOCKER_INFLUXDB_INIT_ADMIN_TOKEN.
  # Outside of blank runs (persistent volume), the Grafana token must match
  # what InfluxDB holds in /var/lib/influxdb2 — typically identical because
  # influxdb_admin_token lives in the destructive group and is not regenerated
  # outside of blank runs.
  - name: InfluxDB
    type: influxdb
    uid: influxdb
    access: proxy
    url: http://influxdb:{{ influxdb_port | default(8086) }}
    jsonData:
      version: Flux
      organization: "{{ influxdb_org | default('nos') }}"
      defaultBucket: "{{ influxdb_bucket | default('default') }}"
      tlsSkipVerify: true
    secureJsonData:
      token: "{{ influxdb_admin_token }}"
    version: 1
    editable: false
{% endif %}
