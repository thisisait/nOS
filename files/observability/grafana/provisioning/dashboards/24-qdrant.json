      "title": "Pending ops",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 3},
      "targets": [{"refId": "A", "expr": "qdrant_pending_operations", "legendFormat": "pending"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 200}]}, "noValue": "no scrape"}, "overrides": []}
