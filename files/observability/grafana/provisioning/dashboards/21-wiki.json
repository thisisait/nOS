    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total Outline documents (from postgres_exporter custom query against outline DB). TODO: requires postgres_exporter 'pg_outline_documents' custom query; falls back to empty until wired.",
