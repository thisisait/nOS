      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "sum(count_over_time({container_name=\"outline-1\"} |~ \"documents\\\\.update\" [5m]))",
          "legendFormat": "edits/5m",
          "range": true,
          "refId": "A"
        }
