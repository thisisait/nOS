      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 27},
      "targets": [
        {"refId": "A", "expr": "vector(0)", "legendFormat": "placeholder"}
      ],
