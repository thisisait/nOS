    {
      "type": "timeseries",
      "id": 11,
      "title": "Container resources — Paperclip",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "targets": [
        {"refId": "A", "expr": "rate(container_cpu_usage_seconds_total{name=~\".*paperclip.*\"}[5m]) * 100", "legendFormat": "cpu% {{name}}"},
        {"refId": "B", "expr": "container_memory_usage_bytes{name=~\".*paperclip.*\"} / 1024 / 1024", "legendFormat": "mem MiB {{name}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
