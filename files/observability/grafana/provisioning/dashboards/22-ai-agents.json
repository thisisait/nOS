      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
      "targets": [
        {"refId": "A", "expr": "sum by (tool) (count_over_time({job=\"openclaw\"} |~ \"tool_call\" | json [1h]))", "legendFormat": "{{tool}}"}
