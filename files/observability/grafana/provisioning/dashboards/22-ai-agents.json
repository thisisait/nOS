      "title": "Agent runs / minute (Wing event stream via Loki)",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "targets": [
        {"refId": "A", "expr": "sum by (service) (count_over_time({job=\"glasswing\"} |~ \"event_type=agent_run\"[1m]))", "legendFormat": "{{service}}"}
