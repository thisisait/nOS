      "title": "Pending approvals — placeholder (Wave 2 PG exporter)",
      "description": "select count(*) from approvals where status='pending'.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 15},
      "targets": [{"refId": "A", "expr": "paperclip_approvals_pending", "legendFormat": "pending"}],
