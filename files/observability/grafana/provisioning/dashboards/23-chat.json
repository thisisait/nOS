    {
      "type": "timeseries",
      "id": 6,
      "title": "Open WebUI request rate (Nginx upstream)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"refId": "A", "expr": "rate(nginx_http_requests_total{host=~\".*openwebui.*|.*chat.*\"}[5m])", "legendFormat": "{{host}} {{status}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Open WebUI 5xx rate (Nginx)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"refId": "A", "expr": "rate(nginx_http_requests_total{host=~\".*openwebui.*|.*chat.*\", status=~\"5..\"}[5m])", "legendFormat": "5xx {{host}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "errps", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "single"}}
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Container resources — Open WebUI",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {"refId": "A", "expr": "rate(container_cpu_usage_seconds_total{name=~\".*openwebui.*|.*open-webui.*\"}[5m]) * 100", "legendFormat": "cpu% {{name}}"},
        {"refId": "B", "expr": "container_memory_usage_bytes{name=~\".*openwebui.*|.*open-webui.*\"} / 1024 / 1024", "legendFormat": "mem MiB {{name}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "logs",
      "id": 9,
      "title": "Open WebUI errors (Loki)",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 24},
      "targets": [
        {"refId": "A", "expr": "{container_name=~\".*openwebui.*|.*open-webui.*\"} |~ \"(?i)error|exception|traceback\"", "maxLines": 200}
      ],
      "options": {"showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none"}
    }
  ],
