# ==============================================================================
# Grafana dashboard provisioning
# Vygenerováno Ansible – ruční úpravy budou přepsány
# ==============================================================================

apiVersion: 1

providers:
  - name: 'Community Dashboards'
    orgId: 1
    folder: 'Mac Studio'
    type: file
    disableDeletion: false
    updateIntervalSeconds: 10
    allowUiUpdates: true
    options:
      path: {{ ansible_env.HOME }}/pazny/observability/dashboards
      foldersFromFilesStructure: false
