// ==============================================================================
// Grafana Alloy configuration (River/Alloy syntax)
// Unified collector: metrics, logs, traces → LGTM stack
// Generated by Ansible – manual edits will be overwritten
// ==============================================================================

// ── Logging ───────────────────────────────────────────────────────────────────
logging {
  level  = "warn"
  format = "logfmt"
}

// ─────────────────────────────────────────────────────────────────────────────
// METRICS
// ─────────────────────────────────────────────────────────────────────────────

// System metrics (CPU, RAM, disk, network) – node_exporter compatible
prometheus.exporter.unix "local" {
  set_collectors = [
    "cpu", "diskstats", "filesystem", "loadavg",
    "meminfo", "netdev", "netstat", "os", "stat",
    "time", "uname", "vmstat",
  ]
}

prometheus.scrape "unix_metrics" {
  targets    = prometheus.exporter.unix.local.targets
  forward_to = [prometheus.remote_write.default.receiver]
  job_name   = "integrations/node_exporter"
  scrape_interval = "15s"
}

{% if alloy_scrape_nginx | default(true) %}
// Nginx metrics (nginx-prometheus-exporter on port 9113)
prometheus.scrape "nginx" {
  targets = [{
    __address__ = "localhost:9113",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "nginx"
  scrape_interval = "30s"
}
{% endif %}

{% if alloy_scrape_phpfpm | default(true) %}
// PHP-FPM metrics (php-fpm_exporter / status page)
prometheus.scrape "phpfpm" {
  targets = [{
    __address__ = "localhost:{{ phpfpm_exporter_port | default(9253) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "phpfpm"
  scrape_interval = "30s"
}
{% endif %}

{% if alloy_scrape_redis | default(true) %}
// Redis metrics
prometheus.exporter.redis "local" {
  redis_addr = "localhost:{{ redis_port | default(6379) }}"
}

prometheus.scrape "redis" {
  targets    = prometheus.exporter.redis.local.targets
  forward_to = [prometheus.remote_write.default.receiver]
  job_name   = "redis"
  scrape_interval = "30s"
}
{% endif %}

// ── Docker service metrics (services with native /metrics endpoints) ─────────

{% if install_miniflux | default(false) %}
// Miniflux — Go process + HTTP request metrics
prometheus.scrape "miniflux" {
  targets = [{
    __address__ = "localhost:{{ miniflux_port | default(3011) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "miniflux"
  metrics_path = "/metrics"
  scrape_interval = "30s"
}
{% endif %}

{% if install_firefly | default(false) %}
// Firefly III — Laravel/PHP process metrics
prometheus.scrape "firefly" {
  targets = [{
    __address__ = "localhost:{{ firefly_port | default(3014) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "firefly"
  metrics_path = "/metrics"
  scrape_interval = "60s"
}
{% endif %}

{% if install_influxdb | default(false) %}
// InfluxDB 2.x — internal metrics
prometheus.scrape "influxdb" {
  targets = [{
    __address__ = "localhost:{{ influxdb_port | default(8086) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "influxdb"
  metrics_path = "/metrics"
  scrape_interval = "30s"
}
{% endif %}

// Self-monitoring – Alloy's own metrics
prometheus.scrape "alloy_self" {
  targets = [{
    __address__ = "localhost:{{ alloy_ui_port | default(12345) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "alloy"
  scrape_interval = "15s"
}

// ── Exporter fleet (Sprint 1 Wave 1 — observability expansion) ───────────────
// Each exporter runs as a container in the observability stack and publishes
// its /metrics endpoint on 127.0.0.1:<port> of the host. Alloy (host-side)
// scrapes via localhost. Toggles and ports live in default.config.yml.

{% if alloy_scrape_postgres_exporter | default(install_postgresql | default(false)) %}
// PostgreSQL exporter (prometheuscommunity/postgres-exporter)
prometheus.scrape "postgres_exporter" {
  targets = [{
    __address__ = "localhost:{{ postgres_exporter_port | default(9187) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "postgres-exporter"
  scrape_interval = "30s"
}
{% endif %}

{% if alloy_scrape_mysqld_exporter | default(install_mariadb | default(false)) %}
// MariaDB / MySQL exporter (prom/mysqld-exporter)
prometheus.scrape "mysqld_exporter" {
  targets = [{
    __address__ = "localhost:{{ mysqld_exporter_port | default(9104) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "mysqld-exporter"
  scrape_interval = "30s"
}
{% endif %}

{% if alloy_scrape_redis_exporter | default(redis_docker | default(false)) %}
// Redis exporter container (oliver006/redis_exporter)
prometheus.scrape "redis_exporter" {
  targets = [{
    __address__ = "localhost:{{ redis_exporter_port | default(9121) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "redis-exporter"
  scrape_interval = "30s"
}
{% endif %}

{% if alloy_scrape_cadvisor | default(true) %}
// cAdvisor — per-container CPU / memory / network / fs metrics
prometheus.scrape "cadvisor" {
  targets = [{
    __address__ = "localhost:{{ cadvisor_port | default(8080) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "cadvisor"
  scrape_interval = "30s"
}
{% endif %}

{% if alloy_scrape_blackbox_self | default(true) %}
// Blackbox exporter self-metrics. Actual probe scrapes (http_2xx against a
// service URL list) live in the Prometheus config, owned by agent A2.
prometheus.scrape "blackbox_self" {
  targets = [{
    __address__ = "localhost:{{ blackbox_exporter_port | default(9115) }}",
  }]
  forward_to  = [prometheus.remote_write.default.receiver]
  job_name    = "blackbox-exporter"
  scrape_interval = "30s"
}
{% endif %}

// Remote write to Prometheus
prometheus.remote_write "default" {
  endpoint {
    url = "http://localhost:{{ prometheus_port | default(9090) }}/api/v1/write"
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// LOGS → Loki
// ─────────────────────────────────────────────────────────────────────────────

{% if alloy_tail_nginx_logs | default(true) %}
// Nginx access logs
local.file_match "nginx_access" {
  path_targets = [{
    __path__ = "{{ homebrew_prefix }}/var/log/nginx/*.access.log",
  }]
}

loki.source.file "nginx_access" {
  targets    = local.file_match.nginx_access.targets
  forward_to = [loki.process.nginx.receiver]
}

loki.process "nginx" {
  forward_to = [loki.write.default.receiver]

  stage.regex {
    expression = `^(?P<remote_addr>\S+) - (?P<remote_user>\S+) \[(?P<time_local>[^\]]+)\] "(?P<method>\S+) (?P<request>[^"]+)" (?P<status>\d+) (?P<bytes_sent>\d+)`
  }

  stage.labels {
    values = {
      method = "",
      status = "",
    }
  }

  stage.static_labels {
    values = {
      job    = "nginx",
      host   = "{{ observability_hostname | default(ansible_facts['hostname']) }}",
    }
  }
}

// Nginx error logs
local.file_match "nginx_error" {
  path_targets = [{
    __path__ = "{{ homebrew_prefix }}/var/log/nginx/*.error.log",
  }]
}

loki.source.file "nginx_error" {
  targets    = local.file_match.nginx_error.targets
  forward_to = [loki.write.default.receiver]
}
{% endif %}

{% if alloy_tail_agent_logs | default(true) %}
// OpenClaw agent logs (.md files in ~/agents/log/)
local.file_match "agent_logs" {
  path_targets = [{
    __path__ = "{{ ansible_facts['env']['HOME'] }}/agents/log/*.md",
  }]
}

loki.source.file "agent_logs" {
  targets    = local.file_match.agent_logs.targets
  forward_to = [loki.write.default.receiver]
}
{% endif %}

{% if alloy_tail_php_logs | default(true) %}
// PHP-FPM logs
local.file_match "php_fpm_logs" {
  path_targets = [{
    __path__ = "{{ homebrew_prefix }}/var/log/php@{{ php_version | default('8.3') }}-fpm.log",
  }]
}

loki.source.file "php_fpm_logs" {
  targets    = local.file_match.php_fpm_logs.targets
  forward_to = [loki.write.default.receiver]
}
{% endif %}

// System logs (macOS unified log – no journald emulation available,
// but brew services logs live in {{ homebrew_prefix }}/var/log/)
local.file_match "homebrew_services" {
  path_targets = [{
    __path__ = "{{ homebrew_prefix }}/var/log/*.log",
  }]
}

loki.source.file "homebrew_services" {
  targets    = local.file_match.homebrew_services.targets
  forward_to = [loki.write.default.receiver]
}

{% if alloy_tail_docker_logs | default(true) %}
// ── All Docker container stdout/stderr → Loki ────────────────────────────────
// Sprint 1 Wave 1: ship every container's logs with discovery labels
// (compose project, service, container name, image) so Grafana can filter
// by stack (`project="observability"`) or service (`service="grafana"`).
//
// Requires Alloy to have access to /var/run/docker.sock. On macOS Docker
// Desktop, the raw socket lives at ~/.docker/run/docker.sock — it's
// symlinked to /var/run/docker.sock, so "unix:///var/run/docker.sock" works.
discovery.docker "docker_targets" {
  host             = "unix:///var/run/docker.sock"
  refresh_interval = "30s"
}

discovery.relabel "docker_targets" {
  targets = discovery.docker.docker_targets.targets

  // Compose project → "stack" label (infra / observability / iiab / …).
  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
    target_label  = "stack"
  }
  // Compose service name → "service" label (grafana, prometheus, mariadb …).
  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service"
  }
  // Container name (without leading "/") → "container".
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }
  // Image (repo:tag) → "image".
  rule {
    source_labels = ["__meta_docker_container_log_stream"]
    target_label  = "stream"
  }
}

loki.source.docker "docker_logs" {
  host          = "unix:///var/run/docker.sock"
  targets       = discovery.docker.docker_targets.targets
  forward_to    = [loki.write.default.receiver]
  relabel_rules = discovery.relabel.docker_targets.rules
  refresh_interval = "30s"
}
{% endif %}

// Loki write endpoint
loki.write "default" {
  endpoint {
    url = "http://localhost:{{ loki_port | default(3100) }}/loki/api/v1/push"
  }
  external_labels = {
    host = "{{ observability_hostname | default(ansible_facts['hostname']) }}",
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// TRACES (OTLP) → Tempo
// ─────────────────────────────────────────────────────────────────────────────

{% if alloy_receive_otlp | default(true) %}
// OTLP receiver – applications send traces via the OpenTelemetry SDK
// Alloy listens on alloy_otlp_*_port (4317/4318) and forwards to Tempo on tempo_otlp_*_port (4327/4328)
otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:{{ alloy_otlp_grpc_port | default(4317) }}"
  }
  http {
    endpoint = "0.0.0.0:{{ alloy_otlp_http_port | default(4318) }}"
  }

  output {
    traces = [otelcol.exporter.otlp.tempo.input]
  }
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "localhost:{{ tempo_otlp_grpc_port | default(4327) }}"
    tls {
      insecure = true
    }
  }
}
{% endif %}
