---
extends: default

rules:
  line-length:
    max: 180
    level: warning
  # Ansible Jinja2 templates use {{ var }} which yamllint flags as
  # "too many spaces inside braces". Disable — incompatible with Jinja2.
  braces:
    min-spaces-inside: 0
    max-spaces-inside-empty: 0
    max-spaces-inside: -1
  brackets:
    min-spaces-inside: 0
    max-spaces-inside-empty: 0
    max-spaces-inside: -1

ignore: |
  .github/workflows/stale.yml
  .venv
  roles
  files/observability
  files/project-wing
  # Jinja2 templates can't be parsed as YAML — `{% if %}` blocks break
  # tokenization. Anatomy plugin templates live outside `roles/` so they
  # need their own exclusion line. Files inside `roles/` are already
  # covered by the `roles` entry above.
  files/anatomy/plugins/*/templates/*.j2
  # Auto-generated contract artifacts (Anatomy A5). They use PyYAML's
  # safe_dump indentation, which differs from yamllint's default
  # `indent-sequences: true (with extra space)` expectation. The
  # contracts-drift CI job already validates byte-stability — running
  # yamllint on top would add only noise.
  files/anatomy/skills/contracts
